<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.erp.mapper.contract.OutsourceProcessingContractWasteItemMapper">

    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.erp.entity.contract.OutsourceProcessingContractWasteItem">
        <id column="废物明细编号" property="wasteItemId"/>
        <result column="条目编号" property="itemId"/>
        <result column="行内顺序" property="rowOrder"/>
        <result column="危废条目编号" property="hazardousWasteItemId"/>
        <result column="废物类别" property="wasteCategory"/>
        <result column="废物代码" property="wasteCode"/>
        <result column="废物名称" property="wasteName"/>
        <result column="废物形态" property="wasteState"/>
        <result column="计划数量" property="plannedQuantity"/>
        <result column="是否不限量" property="unlimitedQuantity"/>
        <result column="计量单位" property="quantityUnit"/>
        <result column="是否启用辅助核算" property="enableAuxiliaryAccounting"/>
        <result column="辅助计量单位" property="auxUnit"/>
        <result column="辅助单位每基础单位数量" property="auxPerBase"/>
        <result column="辅助数量" property="auxQuantity"/>
        <result column="辅助单价" property="auxUnitPrice"/>
        <result column="单价" property="unitPrice"/>
        <result column="超量单价" property="overLimitPrice"/>
        <result column="超量单位" property="overLimitUnit"/>
        <result column="底价" property="floorPrice"/>
        <result column="底价单位" property="floorPriceUnit"/>
        <result column="计价方案" property="pricingStatement"/>
        <result column="付款方" property="payer"/>
        <result column="小计单位" property="subtotalUnit"/>
        <result column="小计数量" property="subtotalQuantity"/>
        <result column="备注" property="remark"/>
        <result column="是否删除" property="isDeleted"/>
        <result column="创建时间" property="createTime"/>
        <result column="更新时间" property="updateTime"/>
        <result column="version" property="version"/>
    </resultMap>

    <!-- 基础列 -->
    <sql id="baseColumns">
        opcwi.废物明细编号, opcwi.条目编号, opcwi.行内顺序, opcwi.危废条目编号, opcwi.废物类别,
        opcwi.废物代码, opcwi.废物名称, opcwi.废物形态, opcwi.计划数量, opcwi.是否不限量,
        opcwi.计量单位, opcwi.是否启用辅助核算, opcwi.辅助计量单位, opcwi.辅助单位每基础单位数量,
        opcwi.辅助数量, opcwi.辅助单价, opcwi.单价, opcwi.超量单价, opcwi.超量单位,
        opcwi.底价, opcwi.底价单位, opcwi.计价方案, opcwi.付款方, opcwi.小计单位, opcwi.小计数量,
        opcwi.备注, opcwi.是否删除, opcwi.创建时间, opcwi.更新时间, opcwi.version
    </sql>

    <!-- 根据条目编号查询 -->
    <select id="selectByItemId" resultMap="BaseResultMap">
        SELECT <include refid="baseColumns"/>
        FROM OUTSOURCE_PROCESSING_CONTRACT_WASTE_ITEM opcwi
        WHERE opcwi.条目编号 = #{itemId}
          AND opcwi.是否删除 = 0
        ORDER BY opcwi.行内顺序 ASC
    </select>

    <!-- 删除条目下的所有废物明细 -->
    <update id="deleteByItemId">
        UPDATE OUTSOURCE_PROCESSING_CONTRACT_WASTE_ITEM
        SET 是否删除 = 1, 更新时间 = NOW()
        WHERE 条目编号 = #{itemId}
    </update>

    <!-- 根据合同编号查询所有废物明细 -->
    <select id="selectByContractId" resultMap="BaseResultMap">
        SELECT <include refid="baseColumns"/>
        FROM OUTSOURCE_PROCESSING_CONTRACT_WASTE_ITEM opcwi
        INNER JOIN OUTSOURCE_PROCESSING_CONTRACT_ITEM opci ON opcwi.条目编号 = opci.条目编号
        WHERE opci.合同编号 = #{contractId}
          AND opcwi.是否删除 = 0
          AND opci.是否删除 = 0
        ORDER BY opci.行号 ASC, opcwi.行内顺序 ASC
    </select>

</mapper>
