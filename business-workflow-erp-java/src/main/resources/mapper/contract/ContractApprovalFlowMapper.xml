<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.erp.mapper.contract.ContractApprovalFlowMapper">

    <resultMap id="ContractApprovalFlowResultMap" type="com.erp.entity.contract.ContractApprovalFlow">
        <id column="审批记录编号" property="approvalFlowId"/>
        <result column="合同编号" property="contractId"/>
        <result column="节点名称" property="nodeName"/>
        <result column="审批人编码" property="approverId"/>
        <result column="审批结果" property="approvalResult"/>
        <result column="审批意见" property="approvalOpinion"/>
        <result column="审批时间" property="approvalTime"/>
        <result column="创建时间" property="createTime"/>
    </resultMap>

    <!-- 根据合同编号查询审批流记录 -->
    <select id="selectByContractId" resultMap="ContractApprovalFlowResultMap">
        SELECT
            审批记录编号,
            合同编号,
            节点名称,
            审批人编码,
            审批结果,
            审批意见,
            审批时间,
            创建时间
        FROM CONTRACT_APPROVAL_FLOW
        WHERE 合同编号 = #{contractId}
        ORDER BY 创建时间 ASC
    </select>

    <!-- 根据合同编号和节点名称查询审批流记录 -->
    <select id="selectByContractIdAndNodeName" resultMap="ContractApprovalFlowResultMap">
        SELECT
            审批记录编号,
            合同编号,
            节点名称,
            审批人编码,
            审批结果,
            审批意见,
            审批时间,
            创建时间
        FROM CONTRACT_APPROVAL_FLOW
        WHERE 合同编号 = #{contractId}
          AND 节点名称 = #{nodeName}
        LIMIT 1
    </select>

</mapper>
















