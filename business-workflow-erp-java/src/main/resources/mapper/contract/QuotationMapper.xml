<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.erp.mapper.contract.QuotationMapper">

    <resultMap id="QuotationResultMap" type="com.erp.entity.contract.Quotation">
        <id column="报价单编号" property="quotationId"/>
        <result column="报价单号" property="quotationNo"/>
        <result column="客户编码" property="customerId"/>
        <result column="customer_snapshot" property="customerSnapshot"/>
        <result column="甲方名称" property="partyAName"/>
        <result column="甲方联系人" property="partyAContact"/>
        <result column="甲方联系电话" property="partyAContactPhone"/>
        <result column="甲方统一社会信用代码" property="partyACreditCode"/>
        <result column="乙方名称" property="partyBName"/>
        <result column="乙方联系人" property="partyBContact"/>
        <result column="乙方联系电话" property="partyBContactPhone"/>
        <result column="乙方统一社会信用代码" property="partyBCreditCode"/>
        <result column="报价状态" property="quotationStatus"/>
        <result column="审核人编码" property="auditorId"/>
        <result column="审核人名称" property="auditorName"/>
        <result column="审核意见" property="auditOpinion"/>
        <result column="审核时间" property="auditTime"/>
        <result column="报价日期" property="quotationDate"/>
        <result column="有效期开始" property="validFrom"/>
        <result column="有效期结束" property="validTo"/>
        <result column="备注" property="remark"/>
        <result column="创建人编码" property="creatorId"/>
        <result column="创建时间" property="createTime"/>
        <result column="更新时间" property="updateTime"/>
    </resultMap>

    <sql id="BaseSelectSql">
        SELECT
            q.报价单编号,
            q.报价单号,
            q.客户编码,
            q.customer_snapshot,
            q.甲方名称,
            q.甲方联系人,
            q.甲方联系电话,
            q.甲方统一社会信用代码,
            q.乙方名称,
            q.乙方联系人,
            q.乙方联系电话,
            q.乙方统一社会信用代码,
            q.报价状态,
            q.审核人编码,
            q.审核人名称,
            q.审核意见,
            q.审核时间,
            q.报价日期,
            q.有效期开始,
            q.有效期结束,
            q.备注,
            q.创建人编码,
            q.创建时间,
            q.更新时间
        FROM QUOTATION q
    </sql>

    <select id="selectQuotationDetail" resultMap="QuotationResultMap">
        <include refid="BaseSelectSql"/>
        WHERE q.报价单编号 = #{quotationId}
    </select>

    <select id="selectQuotationPage" resultMap="QuotationResultMap">
        <include refid="BaseSelectSql"/>
        <where>
            <if test="keyword != null and keyword != ''">
                AND (
                    q.报价单号 LIKE CONCAT('%', #{keyword}, '%')
                    -- 搜索正式客户的名称和联系人
                    OR EXISTS (
                        SELECT 1 FROM CUSTOMER c
                        WHERE c.客户编码 = q.客户编码
                        AND (
                            c.企业名称 LIKE CONCAT('%', #{keyword}, '%')
                            OR c.联系人 LIKE CONCAT('%', #{keyword}, '%')
                        )
                    )
                    -- 搜索临时客户的名称和联系人（从customer_snapshot中提取）
                    OR (
                        JSON_UNQUOTE(JSON_EXTRACT(q.customer_snapshot, '$.customerType')) = 'TEMPORARY'
                        AND (
                            JSON_UNQUOTE(JSON_EXTRACT(q.customer_snapshot, '$.customerName')) LIKE CONCAT('%', #{keyword}, '%')
                            OR JSON_UNQUOTE(JSON_EXTRACT(q.customer_snapshot, '$.contactPerson')) LIKE CONCAT('%', #{keyword}, '%')
                        )
                    )
                )
            </if>
            <if test="quotationNoSearch != null and quotationNoSearch != ''">
                AND q.报价单号 LIKE CONCAT('%', #{quotationNoSearch}, '%')
            </if>
            <if test="customerName != null and customerName != ''">
                AND (
                    -- 搜索正式客户的名称和联系人
                    EXISTS (
                        SELECT 1 FROM CUSTOMER c
                        WHERE c.客户编码 = q.客户编码
                        AND (
                            c.企业名称 LIKE CONCAT('%', #{customerName}, '%')
                            OR c.联系人 LIKE CONCAT('%', #{customerName}, '%')
                        )
                    )
                    -- 搜索临时客户的名称和联系人（从customer_snapshot中提取）
                    OR (
                        JSON_UNQUOTE(JSON_EXTRACT(q.customer_snapshot, '$.customerType')) = 'TEMPORARY'
                        AND (
                            JSON_UNQUOTE(JSON_EXTRACT(q.customer_snapshot, '$.customerName')) LIKE CONCAT('%', #{customerName}, '%')
                            OR JSON_UNQUOTE(JSON_EXTRACT(q.customer_snapshot, '$.contactPerson')) LIKE CONCAT('%', #{customerName}, '%')
                        )
                    )
                )
            </if>
            <if test="customerId != null">
                AND q.客户编码 = #{customerId}
            </if>
            <if test="quotationStatus != null and quotationStatus != ''">
                AND q.报价状态 = #{quotationStatus}
            </if>
            <if test="pricingMode != null and pricingMode != ''">
                <choose>
                    <when test="pricingMode == 'PACKAGE'">
                        AND EXISTS (
                            SELECT 1 FROM QUOTATION_ITEM qi
                            WHERE qi.报价单编号 = q.报价单编号
                            AND qi.报价模式 = '总价包干'
                        )
                        AND NOT EXISTS (
                            SELECT 1 FROM QUOTATION_ITEM qi
                            WHERE qi.报价单编号 = q.报价单编号
                            AND qi.报价模式 = '按量结算'
                        )
                    </when>
                    <when test="pricingMode == 'UNIT'">
                        AND EXISTS (
                            SELECT 1 FROM QUOTATION_ITEM qi
                            WHERE qi.报价单编号 = q.报价单编号
                            AND qi.报价模式 = '按量结算'
                        )
                        AND NOT EXISTS (
                            SELECT 1 FROM QUOTATION_ITEM qi
                            WHERE qi.报价单编号 = q.报价单编号
                            AND qi.报价模式 = '总价包干'
                        )
                    </when>
                    <when test="pricingMode == 'MIXED'">
                        AND EXISTS (
                            SELECT 1 FROM QUOTATION_ITEM qi1
                            WHERE qi1.报价单编号 = q.报价单编号
                            AND qi1.报价模式 = '总价包干'
                        )
                        AND EXISTS (
                            SELECT 1 FROM QUOTATION_ITEM qi2
                            WHERE qi2.报价单编号 = q.报价单编号
                            AND qi2.报价模式 = '按量结算'
                        )
                    </when>
                </choose>
            </if>
            <if test="quotationNo != null and quotationNo != ''">
                AND q.报价单号 LIKE CONCAT('%', #{quotationNo}, '%')
            </if>
            <if test="internalCode != null and internalCode != ''">
                AND q.报价单号 LIKE CONCAT('%', #{internalCode}, '%')
            </if>
            <if test="creatorName != null and creatorName != ''">
                AND EXISTS (
                    SELECT 1 FROM EMPLOYEE e
                    WHERE e.员工编码 = q.创建人编码
                    AND e.员工姓名 LIKE CONCAT('%', #{creatorName}, '%')
                )
            </if>
            <if test="validFrom != null">
                AND q.有效期开始 &gt;= #{validFrom}
            </if>
            <if test="validTo != null">
                AND q.有效期结束 &lt;= #{validTo}
            </if>
            <if test="pdfGenerated != null">
                <choose>
                    <when test="pdfGenerated">
                        AND EXISTS (
                            SELECT 1 FROM FILE f
                            WHERE f.关联业务类型 = 'QUOTATION'
                              AND f.关联业务ID = q.报价单编号
                              AND f.文件状态 = '正常'
                        )
                    </when>
                    <otherwise>
                        AND NOT EXISTS (
                            SELECT 1 FROM FILE f
                            WHERE f.关联业务类型 = 'QUOTATION'
                              AND f.关联业务ID = q.报价单编号
                              AND f.文件状态 = '正常'
                        )
                    </otherwise>
                </choose>
            </if>
            <if test="creatorFilter != null">
                AND q.创建人编码 = #{creatorFilter}
            </if>
        </where>
        <choose>
            <when test="sortField != null and sortField != ''">
                ORDER BY
                <choose>
                    <when test="sortField == 'quotationId'">q.报价单编号</when>
                    <when test="sortField == 'quotationCode' or sortField == 'quotationNo'">q.报价单号</when>
                    <when test="sortField == 'customerName'">
                        (SELECT c.企业名称 FROM CUSTOMER c WHERE c.客户编码 = q.客户编码)
                    </when>
                    <when test="sortField == 'quotationStatus'">q.报价状态</when>
                    <when test="sortField == 'validFrom'">q.有效期开始</when>
                    <when test="sortField == 'createTime'">q.创建时间</when>
                    <otherwise>q.创建时间</otherwise>
                </choose>
                <choose>
                    <when test="sortOrder == 'asc'">ASC</when>
                    <when test="sortOrder == 'desc'">DESC</when>
                    <otherwise>DESC</otherwise>
                </choose>
            </when>
            <otherwise>
                ORDER BY q.创建时间 DESC
            </otherwise>
        </choose>
    </select>

    <select id="selectByCustomerId" resultMap="QuotationResultMap">
        SELECT
            q.报价单编号,
            q.报价单号,
            q.客户编码,
            q.customer_snapshot,
            q.甲方名称,
            q.甲方联系人,
            q.甲方联系电话,
            q.甲方统一社会信用代码,
            q.乙方名称,
            q.乙方联系人,
            q.乙方联系电话,
            q.乙方统一社会信用代码,
            q.报价状态,
            q.审核人编码,
            q.审核人名称,
            q.审核意见,
            q.审核时间,
            q.报价日期,
            q.有效期开始,
            q.有效期结束,
            q.备注,
            q.创建人编码,
            q.创建时间,
            q.更新时间
        FROM QUOTATION q
        WHERE q.客户编码 = #{customerId}
        ORDER BY q.创建时间 DESC
    </select>

</mapper>


