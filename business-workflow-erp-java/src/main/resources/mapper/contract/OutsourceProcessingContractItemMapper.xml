<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.erp.mapper.contract.OutsourceProcessingContractItemMapper">

    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.erp.entity.contract.OutsourceProcessingContractItem">
        <id column="条目编号" property="itemId"/>
        <result column="合同编号" property="contractId"/>
        <result column="行号" property="rowNumber"/>
        <result column="计价方式" property="pricingMode"/>
        <result column="付款方" property="payer"/>
        <result column="计价方案" property="pricingStatement"/>
        <result column="小计摘要" property="subtotalSummary"/>
        <result column="备注" property="remark"/>
        <result column="是否删除" property="isDeleted"/>
        <result column="创建时间" property="createTime"/>
        <result column="更新时间" property="updateTime"/>
        <result column="version" property="version"/>
    </resultMap>

    <!-- 基础列 -->
    <sql id="baseColumns">
        opci.条目编号, opci.合同编号, opci.行号, opci.计价方式, opci.付款方,
        opci.计价方案, opci.小计摘要, opci.备注,
        opci.是否删除, opci.创建时间, opci.更新时间, opci.version
    </sql>

    <!-- 根据合同编号查询 -->
    <select id="selectByContractId" resultMap="BaseResultMap">
        SELECT <include refid="baseColumns"/>
        FROM OUTSOURCE_PROCESSING_CONTRACT_ITEM opci
        WHERE opci.合同编号 = #{contractId}
          AND opci.是否删除 = 0
        ORDER BY opci.行号 ASC
    </select>

    <!-- 删除合同下的所有报价组 -->
    <update id="deleteByContractId">
        UPDATE OUTSOURCE_PROCESSING_CONTRACT_ITEM
        SET 是否删除 = 1, 更新时间 = NOW()
        WHERE 合同编号 = #{contractId}
    </update>

</mapper>
