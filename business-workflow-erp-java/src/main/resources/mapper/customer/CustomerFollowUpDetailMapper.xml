<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.erp.mapper.customer.CustomerFollowUpDetailMapper">

    <resultMap id="CustomerFollowUpDetailResultMap" type="com.erp.entity.customer.CustomerFollowUpDetail">
        <id column="跟进详细记录编号" property="detailId"/>
        <result column="跟进记录编号" property="followUpId"/>
        <result column="跟进时间" property="followTime"/>
        <result column="跟进内容" property="followContent"/>
        <result column="跟进状态" property="followStatus"/>
        <result column="创建人编码" property="creatorId"/>
        <result column="创建时间" property="createTime"/>
        <result column="更新时间" property="updateTime"/>
        <result column="备注" property="remark"/>
        <result column="creatorName" property="creatorName"/>
    </resultMap>

    <resultMap id="DetailResponseResultMap" type="com.erp.controller.customer.dto.CustomerFollowUpDetailResponse">
        <id column="detailId" property="detailId"/>
        <result column="followUpId" property="followUpId"/>
        <result column="followTime" property="followTime"/>
        <result column="followContent" property="followContent"/>
        <result column="followStatus" property="followStatus"/>
        <result column="creatorId" property="creatorId"/>
        <result column="createTime" property="createTime"/>
        <result column="updateTime" property="updateTime"/>
        <result column="remark" property="remark"/>
        <result column="creatorName" property="creatorName"/>
    </resultMap>

    <sql id="BaseSelectSql">
        SELECT
            d.跟进详细记录编号 AS detailId,
            d.跟进记录编号 AS followUpId,
            d.跟进时间 AS followTime,
            d.跟进内容 AS followContent,
            d.跟进状态 AS followStatus,
            d.创建人编码 AS creatorId,
            d.创建时间 AS createTime,
            d.更新时间 AS updateTime,
            d.备注 AS remark,
            e.员工姓名 AS creatorName
        FROM CUSTOMER_FOLLOW_UP_DETAIL d
        LEFT JOIN EMPLOYEE e ON d.创建人编码 = e.员工编码
    </sql>

    <!-- 根据跟进记录ID查询明细列表 -->
    <select id="selectByFollowUpId" resultMap="CustomerFollowUpDetailResultMap">
        SELECT
            d.跟进详细记录编号,
            d.跟进记录编号,
            d.跟进时间,
            d.跟进内容,
            d.跟进状态,
            d.创建人编码,
            d.创建时间,
            d.更新时间,
            d.备注,
            e.员工姓名 AS creatorName
        FROM CUSTOMER_FOLLOW_UP_DETAIL d
        LEFT JOIN EMPLOYEE e ON d.创建人编码 = e.员工编码
        WHERE d.跟进记录编号 = #{followUpId}
        ORDER BY d.跟进时间 DESC
    </select>

    <!-- 根据跟进记录ID删除所有明细 -->
    <delete id="deleteByFollowUpId">
        DELETE FROM CUSTOMER_FOLLOW_UP_DETAIL
        WHERE 跟进记录编号 = #{followUpId}
    </delete>

    <!-- 根据明细ID删除 -->
    <delete id="deleteByDetailId">
        DELETE FROM CUSTOMER_FOLLOW_UP_DETAIL
        WHERE 跟进详细记录编号 = #{detailId}
    </delete>

    <!-- 批量删除明细 -->
    <delete id="deleteBatchByIds">
        DELETE FROM CUSTOMER_FOLLOW_UP_DETAIL
        WHERE 跟进详细记录编号 IN
        <foreach collection="detailIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <!-- 查询明细详情（包含创建人姓名） -->
    <select id="selectDetailWithCreator" resultMap="DetailResponseResultMap">
        <include refid="BaseSelectSql"/>
        WHERE d.跟进详细记录编号 = #{detailId}
    </select>

</mapper>
