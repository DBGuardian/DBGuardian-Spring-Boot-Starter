<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.erp.mapper.oa.OaApprovalRecordMapper">

    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.erp.entity.oa.OaApprovalRecord">
        <id column="审核记录编号" property="approvalRecordId"/>
        <result column="审核编号" property="approvalNo"/>
        <result column="来源表名" property="sourceTable"/>
        <result column="来源表中文名称" property="sourceTableName"/>
        <result column="来源记录编号" property="sourceId"/>
        <result column="关联单号" property="sourceNo"/>
        <result column="审核标题" property="title"/>
        <result column="提交人编码" property="submitterId"/>
        <result column="提交人姓名" property="submitterName"/>
        <result column="审核人编码" property="approverId"/>
        <result column="审核人姓名" property="approverName"/>
        <result column="审核状态" property="approvalStatus"/>
        <result column="审核次数" property="approvalCount"/>
        <result column="提交时间" property="submitTime"/>
        <result column="审核时间" property="approvalTime"/>
        <result column="创建时间" property="createTime"/>
        <result column="更新时间" property="updateTime"/>
        <result column="是否删除" property="deleted"/>
    </resultMap>

    <!-- 分页查询OA审核记录列表 -->
    <select id="selectPageList" resultMap="BaseResultMap">
        SELECT
            审核记录编号,
            审核编号,
            来源表名,
            来源表中文名称,
            来源记录编号,
            关联单号,
            审核标题,
            提交人编码,
            提交人姓名,
            审核人编码,
            审核人姓名,
            审核状态,
            审核次数,
            提交时间,
            审核时间,
            创建时间,
            更新时间
        FROM OA_APPROVAL_RECORD
        <where>
            是否删除 = 0
            <!-- 关键字搜索 -->
            <if test="keyword != null and keyword != ''">
                AND (
                    审核编号 LIKE CONCAT('%', #{keyword}, '%')
                    OR 关联单号 LIKE CONCAT('%', #{keyword}, '%')
                    OR 审核标题 LIKE CONCAT('%', #{keyword}, '%')
                    OR 提交人姓名 LIKE CONCAT('%', #{keyword}, '%')
                    OR 审核人姓名 LIKE CONCAT('%', #{keyword}, '%')
                    OR 来源表中文名称 LIKE CONCAT('%', #{keyword}, '%')
                )
            </if>
            <!-- 业务类型筛选 -->
            <if test="businessType != null and businessType != ''">
                AND 来源表名 = #{businessType}
            </if>
            <!-- 审核状态筛选 -->
            <if test="approvalStatus != null and approvalStatus != ''">
                AND 审核状态 = #{approvalStatus}
            </if>
            <!-- 视图范围筛选 -->
            <if test="viewScope == 'pending'">
                AND 审核状态 = '待审核'
            </if>
            <if test="viewScope == 'submitted'">
                AND 提交人编码 = #{submitterId}
            </if>
            <if test="viewScope == 'processed'">
                AND 审核状态 IN ('已通过', '已驳回', '已撤回')
            </if>
            <!-- 提交人筛选 -->
            <if test="submitterId != null">
                AND 提交人编码 = #{submitterId}
            </if>
            <!-- 审核人筛选 -->
            <if test="approverId != null">
                AND 审核人编码 = #{approverId}
            </if>
            <!-- 日期范围筛选 -->
            <if test="startDate != null and startDate != ''">
                AND DATE(提交时间) &gt;= #{startDate}
            </if>
            <if test="endDate != null and endDate != ''">
                AND DATE(提交时间) &lt;= #{endDate}
            </if>
            <!-- 未审核天数筛选（超过指定天数未审核） -->
            <if test="unapprovedDays != null and unapprovedDays > 0">
                AND 审核状态 = '待审核'
                AND DATE_SUB(CURDATE(), INTERVAL #{unapprovedDays} DAY) &gt;= DATE(提交时间)
            </if>
        </where>
        ORDER BY 提交时间 DESC
    </select>

    <!-- 统计OA审核记录数量 -->
    <select id="selectCount" resultType="java.lang.Long">
        SELECT COUNT(*)
        FROM OA_APPROVAL_RECORD
        <where>
            是否删除 = 0
            <if test="approvalStatus != null and approvalStatus != ''">
                AND 审核状态 = #{approvalStatus}
            </if>
            <if test="viewScope == 'pending'">
                AND 审核状态 = '待审核'
                AND 审核人编码 = #{approverId}
            </if>
            <if test="viewScope == 'submitted'">
                AND 提交人编码 = #{submitterId}
            </if>
            <if test="viewScope == 'processed'">
                AND 审核状态 IN ('已通过', '已驳回', '已撤回')
            </if>
            <if test="submitTime != null">
                AND DATE_SUB(CURDATE(), INTERVAL 3 DAY) &gt;= DATE(提交时间)
            </if>
        </where>
    </select>

</mapper>
