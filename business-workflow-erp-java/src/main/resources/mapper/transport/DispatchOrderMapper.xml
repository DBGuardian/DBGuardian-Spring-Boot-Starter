<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.erp.mapper.transport.DispatchOrderMapper">

    <resultMap id="DispatchOrderResultMap" type="com.erp.entity.transport.DispatchOrder">
        <id column="运输单编号" property="dispatchId"/>
        <result column="运输单号" property="dispatchCode"/>
        <result column="调度员编码" property="dispatcherId"/>
        <result column="收运通知单号" property="noticeCode"/>
        <result column="承运单位名称" property="carrierName"/>
        <result column="营运证件号" property="operationLicenseNo"/>
        <result column="承运单位地址" property="carrierAddress"/>
        <result column="承运单位联系电话" property="carrierPhone"/>
        <result column="驾驶员姓名" property="driverName"/>
        <result column="驾驶员联系电话" property="driverPhone"/>
        <result column="运输工具" property="transportTool"/>
        <result column="车辆编号" property="vehicleId"/>
        <result column="运输车辆号牌" property="plateNo"/>
        <result column="运输起点" property="startPoint"/>
        <result column="实际起运时间" property="departAt"/>
        <result column="总计划转移数量" property="planQuantityTon"/>
        <result column="派车时间" property="dispatchAt"/>
        <result column="调度备注" property="dispatcherRemark"/>
        <result column="状态" property="status"/>
        <result column="创建时间" property="createTime"/>
        <result column="更新时间" property="updateTime"/>
        <result column="是否锁定" property="locked"/>
        <result column="锁定时间" property="lockTime"/>
        <result column="锁定人编码" property="lockUserId"/>
        <result column="锁定原因" property="lockReason"/>
        <result column="weighingSlipCode" property="weighingSlipCode"/>
    </resultMap>

    <select id="selectByDispatchCode" parameterType="string" resultMap="DispatchOrderResultMap">
        SELECT * FROM DISPATCH_ORDER WHERE 运输单号 = #{dispatchCode}
    </select>

    <select id="selectByNoticeCode" parameterType="string" resultMap="DispatchOrderResultMap">
        SELECT * FROM DISPATCH_ORDER WHERE 收运通知单号 = #{noticeCode}
    </select>

    <select id="selectByNoticeCodeForUpdate" parameterType="string" resultMap="DispatchOrderResultMap">
        SELECT * FROM DISPATCH_ORDER WHERE 收运通知单号 = #{noticeCode} FOR UPDATE
    </select>

    <select id="selectMaxDispatchCodeByPrefix" parameterType="string" resultType="string">
        SELECT MAX(运输单号) FROM DISPATCH_ORDER WHERE 运输单号 LIKE CONCAT(#{prefix}, '%')
    </select>

    <select id="countByDispatchCode" parameterType="string" resultType="int">
        SELECT COUNT(1) FROM DISPATCH_ORDER WHERE 运输单号 = #{dispatchCode}
    </select>

    <select id="countByNoticeCode" parameterType="string" resultType="int">
        SELECT COUNT(1) FROM DISPATCH_ORDER WHERE 收运通知单号 = #{noticeCode}
    </select>

    <!-- 基础查询SQL片段 -->
    <sql id="BaseSelectSql">
        SELECT
            do.`运输单编号`,
            do.`运输单号`,
            do.`调度员编码`,
            do.`收运通知单号`,
            do.`承运单位名称`,
            do.`营运证件号`,
            do.`承运单位地址`,
            do.`承运单位联系电话`,
            do.`驾驶员姓名`,
            do.`驾驶员联系电话`,
            do.`运输工具`,
            do.`车辆编号`,
            do.`运输车辆号牌`,
            do.`运输起点`,
            do.`实际起运时间`,
            do.`总计划转移数量`,
            do.`派车时间`,
            do.`调度备注`,
            do.`状态`,
            do.`创建时间`,
            do.`更新时间`,
            do.`是否锁定`,
            do.`锁定时间`,
            do.`锁定人编码`,
            do.`锁定原因`,
            pn.`合同号`,
            don.`运输终点` AS endPoint,
            don.`实际到达时间` AS arriveAt,
            ws.`总磅单号` AS weighingSlipCode
        FROM DISPATCH_ORDER do
        LEFT JOIN PICKUP_NOTICE pn ON do.`收运通知单号` = pn.`收运通知单号`
        LEFT JOIN DISPATCH_ORDER_NOTICE don ON do.`运输单号` = don.`运输单号`
        LEFT JOIN WEIGHING_SLIP_DISPATCH wsd ON do.`运输单号` = wsd.`运输单号`
        LEFT JOIN WEIGHING_SLIP ws ON wsd.`总磅单编号` = ws.`总磅单编号`
    </sql>

    <!-- 运输单分页查询 -->
    <select id="selectDispatchOrderPage" resultMap="DispatchOrderResultMap">
        <include refid="BaseSelectSql"/>
        <where>
            <if test="dispatchCode != null and dispatchCode != '' and dispatchCode.trim() != ''">
                AND do.`运输单号` LIKE CONCAT('%', #{dispatchCode}, '%')
            </if>
            <if test="noticeCode != null and noticeCode != '' and noticeCode.trim() != ''">
                AND do.`收运通知单号` LIKE CONCAT('%', #{noticeCode}, '%')
            </if>
            <if test="contractCode != null and contractCode != '' and contractCode.trim() != ''">
                AND pn.`合同号` LIKE CONCAT('%', #{contractCode}, '%')
            </if>
            <if test="carrierName != null and carrierName != '' and carrierName.trim() != ''">
                AND do.`承运单位名称` LIKE CONCAT('%', #{carrierName}, '%')
            </if>
            <if test="driverName != null and driverName != '' and driverName.trim() != ''">
                AND do.`驾驶员姓名` LIKE CONCAT('%', #{driverName}, '%')
            </if>
            <if test="plateNo != null and plateNo != '' and plateNo.trim() != ''">
                AND do.`运输车辆号牌` LIKE CONCAT('%', #{plateNo}, '%')
            </if>
            <if test="status != null and status != '' and status.trim() != ''">
                AND do.`状态` = #{status}
            </if>
            <if test="locked != null">
                AND do.`是否锁定` = #{locked}
            </if>
            <if test="dispatcherId != null">
                AND do.`调度员编码` = #{dispatcherId}
            </if>
            <!-- 数据范围过滤：仅查看自己创建的运输单 -->
            <if test="creatorFilter != null">
                AND do.`调度员编码` = #{creatorFilter}
            </if>
            <if test="startTime != null">
                AND do.`创建时间` &gt;= #{startTime}
            </if>
            <if test="endTime != null">
                AND do.`创建时间` &lt;= #{endTime}
            </if>
        </where>
        <choose>
            <when test="sortField != null and sortField != ''">
                ORDER BY
                <choose>
                    <when test="sortField == 'dispatchId'">do.`运输单编号`</when>
                    <when test="sortField == 'dispatchCode'">do.`运输单号`</when>
                    <when test="sortField == 'noticeCode'">do.`收运通知单号`</when>
                    <when test="sortField == 'contractCode'">pn.`合同号`</when>
                    <when test="sortField == 'carrierName'">do.`承运单位名称`</when>
                    <when test="sortField == 'driverName'">do.`驾驶员姓名`</when>
                    <when test="sortField == 'plateNo'">do.`运输车辆号牌`</when>
                    <when test="sortField == 'status'">do.`状态`</when>
                    <when test="sortField == 'dispatchAt'">do.`派车时间`</when>
                    <when test="sortField == 'departAt'">do.`实际起运时间`</when>
                    <when test="sortField == 'createTime'">do.`创建时间`</when>
                    <otherwise>do.`创建时间`</otherwise>
                </choose>
                <choose>
                    <when test="sortOrder == 'asc'">ASC</when>
                    <when test="sortOrder == 'desc'">DESC</when>
                    <otherwise>DESC</otherwise>
                </choose>
            </when>
            <otherwise>
                ORDER BY do.`创建时间` DESC, do.`运输单编号` DESC
            </otherwise>
        </choose>
    </select>

</mapper>

