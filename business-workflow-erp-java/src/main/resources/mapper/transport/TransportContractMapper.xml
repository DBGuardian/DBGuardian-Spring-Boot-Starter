<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.erp.mapper.transport.TransportContractMapper">

    <!-- ResultMap：TRANSPORT_CONTRACT 表所有字段 -->
    <resultMap id="TransportContractResultMap" type="com.erp.entity.transport.TransportContract">
        <id     column="合同编号"     property="contractId"/>
        <result column="合同单号"     property="contractNo"/>
        <!-- 签约方信息（甲方/承运方） -->
        <result column="签约类型"         property="signingType"/>
        <result column="承运方名称"       property="carrierName"/>
        <result column="联系人"           property="contactPerson"/>
        <result column="联系电话"         property="contactPhone"/>
        <result column="身份证号码"       property="idCardNo"/>
        <result column="统一社会信用代码" property="creditCode"/>
        <result column="银行名称"         property="bankName"/>
        <result column="银行卡号"         property="cardNumber"/>
        <result column="账户名称"         property="accountName"/>
        <!-- 乙方信息 -->
        <result column="乙方名称"                       property="partyBName"/>
        <result column="乙方统一社会信用代码"           property="partyBCreditCode"/>
        <result column="乙方联系人"                     property="partyBContactPerson"/>
        <result column="乙方联系电话"                   property="partyBContactPhone"/>
        <!-- 合同期限 -->
        <result column="签订时间"       property="signTime"/>
        <result column="有效期开始"    property="validFrom"/>
        <result column="有效期结束"    property="validTo"/>
        <!-- 结算方式 -->
        <result column="结算方式"       property="settlementMethod"/>
        <result column="单价"           property="unitPrice"/>
        <result column="计量单位"       property="unit"/>
        <!-- 审核与状态 -->
        <result column="合同状态"       property="status"/>
        <result column="审核意见"       property="auditOpinion"/>
        <result column="审核人编码"     property="auditorId"/>
        <result column="审核人姓名"     property="auditorName"/>
        <result column="审核时间"       property="auditTime"/>
        <!-- 合同文件 -->
        <result column="合同文件编号"   property="contractFileId"/>
        <result column="合同文件路径"   property="contractFilePath"/>
        <!-- 其他 -->
        <result column="备注"           property="remark"/>
        <result column="创建人编码"   property="creatorId"/>
        <result column="创建人姓名"   property="creatorName"/>
        <result column="创建时间"       property="createTime"/>
        <result column="更新时间"     property="updateTime"/>
    </resultMap>

    <!-- 动态 WHERE 条件 -->
    <sql id="ListWhereConditions">
        <where>
            tc.是否删除 = 0
            <if test="contractNo != null and contractNo != ''">
                AND tc.合同单号 LIKE CONCAT('%', #{contractNo}, '%')
            </if>
            <if test="carrierName != null and carrierName != ''">
                AND tc.承运方名称 LIKE CONCAT('%', #{carrierName}, '%')
            </if>
            <if test="signingType != null and signingType != ''">
                AND tc.签约类型 = #{signingType}
            </if>
            <if test="settlementMethod != null and settlementMethod != ''">
                AND tc.结算方式 = #{settlementMethod}
            </if>
            <if test="status != null and status != ''">
                AND tc.合同状态 = #{status}
            </if>
            <if test="signTimeStart != null and signTimeStart != ''">
                AND tc.签订时间 &gt;= #{signTimeStart}
            </if>
            <if test="signTimeEnd != null and signTimeEnd != ''">
                AND tc.签订时间 &lt;= #{signTimeEnd}
            </if>
            <if test="creatorFilter != null">
                AND tc.创建人编码 = #{creatorFilter}
            </if>
        </where>
    </sql>

    <!-- 分页查询列表 -->
    <select id="selectPageList" resultMap="TransportContractResultMap">
        SELECT
            tc.合同编号,
            tc.合同单号,
            tc.签约类型,
            tc.承运方名称,
            tc.联系人,
            tc.联系电话,
            tc.身份证号码,
            tc.统一社会信用代码,
            tc.银行名称,
            tc.银行卡号,
            tc.账户名称,
            tc.乙方名称,
            tc.乙方统一社会信用代码,
            tc.乙方联系人,
            tc.乙方联系电话,
            tc.签订时间,
            tc.有效期开始,
            tc.有效期结束,
            tc.结算方式,
            tc.单价,
            tc.计量单位,
            tc.合同状态,
            tc.审核意见,
            tc.审核人编码,
            tc.审核人姓名,
            tc.审核时间,
            tc.合同文件编号,
            tc.合同文件路径,
            tc.备注,
            tc.创建人编码,
            tc.创建人姓名,
            tc.创建时间,
            tc.更新时间
        FROM TRANSPORT_CONTRACT tc
        <include refid="ListWhereConditions"/>
        <choose>
            <when test="sortField != null and sortField != ''">
                <choose>
                    <when test="sortField == 'contractId'">ORDER BY tc.合同编号</when>
                    <when test="sortField == 'contractNo'">ORDER BY tc.合同单号</when>
                    <when test="sortField == 'carrierName'">ORDER BY tc.承运方名称</when>
                    <when test="sortField == 'signTime'">ORDER BY tc.签订时间</when>
                    <when test="sortField == 'validTo'">ORDER BY tc.有效期结束</when>
                    <when test="sortField == 'status'">ORDER BY tc.合同状态</when>
                    <when test="sortField == 'createTime'">ORDER BY tc.创建时间</when>
                    <otherwise>ORDER BY tc.创建时间</otherwise>
                </choose>
                <choose>
                    <when test="sortOrder == 'asc'"> ASC</when>
                    <otherwise> DESC</otherwise>
                </choose>
            </when>
            <otherwise>ORDER BY tc.创建时间 DESC</otherwise>
        </choose>
        LIMIT #{offset}, #{size}
    </select>

    <!-- 查询总数 -->
    <select id="selectPageCount" resultType="long">
        SELECT COUNT(1)
        FROM TRANSPORT_CONTRACT tc
        <include refid="ListWhereConditions"/>
    </select>

    <!-- 统计各状态合同数量 -->
    <select id="selectStatusCounts" resultType="java.util.Map">
        SELECT
            CAST(SUM(CASE WHEN 合同状态 = '待审核' THEN 1 ELSE 0 END) AS SIGNED) AS draft,
            CAST(SUM(CASE WHEN 合同状态 = '审核中' THEN 1 ELSE 0 END) AS SIGNED) AS reviewing,
            CAST(SUM(CASE WHEN 合同状态 = '执行中' THEN 1 ELSE 0 END) AS SIGNED) AS executing,
            CAST(SUM(CASE WHEN 合同状态 = '已完结' THEN 1 ELSE 0 END) AS SIGNED) AS completed
        FROM TRANSPORT_CONTRACT
        WHERE 是否删除 = 0
    </select>

    <!-- 运输合同查询（关联车辆信息）- 不分页 -->
    <select id="selectContractWithVehicleList" resultType="java.util.Map">
        SELECT
            tc.合同编号 AS contractId,
            tc.合同单号 AS contractNo,
            tc.承运方名称 AS carrierName
        FROM TRANSPORT_CONTRACT tc
        WHERE tc.是否删除 = 0
        ORDER BY tc.创建时间 DESC
    </select>

    <!-- 统计指定合同关联的车辆在 DISPATCH_ORDER 中运输车辆号牌为空的记录数量 -->
    <select id="countDispatchPlateEmptyByContractId" resultType="java.lang.Long">
        SELECT COUNT(1)
        FROM DISPATCH_ORDER do_t
        INNER JOIN TRANSPORT_CONTRACT_VEHICLE tcv ON tcv.合同编号 = #{contractId}
        INNER JOIN VEHICLE v ON v.车辆编号 = tcv.车辆编号
        WHERE do_t.运输车辆号牌 = v.车牌号
        AND (do_t.车辆编号 IS NULL OR do_t.车辆编号 = 0)
    </select>

    <!-- 搜索运输合同（下拉框用） -->
    <select id="searchContracts" resultType="java.util.Map">
        SELECT
            tc.合同编号 AS contractId,
            tc.合同单号 AS contractNo,
            tc.承运方名称 AS carrierName
        FROM TRANSPORT_CONTRACT tc
        WHERE tc.是否删除 = 0
        <if test="viewScope == 'SELF' and creatorId != null">
            AND tc.创建人编号 = #{creatorId}
        </if>
        <if test="keyword != null and keyword != ''">
            AND (
                tc.合同单号 LIKE CONCAT('%', #{keyword}, '%')
                OR tc.承运方名称 LIKE CONCAT('%', #{keyword}, '%')
            )
        </if>
        ORDER BY tc.创建时间 DESC
    </select>

</mapper>
