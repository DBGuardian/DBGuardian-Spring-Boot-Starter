<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.erp.mapper.production.PickupNoticeItemMapper">

    <resultMap id="PickupNoticeItemResultMap" type="com.erp.entity.production.PickupNoticeItem">
        <id column="转移废物明细编号" property="itemId"/>
        <result column="收运通知单号" property="noticeCode"/>
        <result column="合同危废明细编号" property="contractWasteItemId"/>
        <result column="危废条目编号" property="hazardousWasteItemId"/>
        <result column="废物名称" property="wasteName"/>
        <result column="废物代码" property="wasteCode"/>
        <result column="危险特性" property="hazardFeature"/>
        <result column="废物形态" property="form"/>
        <result column="有害成分名称" property="hazardousComponentName"/>
        <!-- 基本核算相关字段 -->
        <result column="计划转移数量" property="plannedQtyTon"/>
        <result column="基本计量单位" property="measureUnit"/>
        <!-- 辅助核算相关字段 -->
        <result column="是否启用辅助核算" property="enableAuxiliaryAccounting"/>
        <result column="辅助计量单位" property="auxUnit"/>
        <result column="辅助单位每基础单位数量" property="auxPerBase"/>
        <result column="辅助数量" property="auxQuantity"/>
        <result column="创建时间" property="createTime"/>
        <result column="更新时间" property="updateTime"/>
        <!-- 危废类别信息（通过关联查询获得） -->
        <result column="废物类别" property="wasteCategory"/>
    </resultMap>

    <sql id="BaseSelectSql">
        SELECT
            pni.转移废物明细编号,
            pni.收运通知单号,
            pni.合同危废明细编号,
            pni.危废条目编号,
            pni.废物名称,
            pni.废物代码,
            pni.危险特性,
            pni.废物形态,
            pni.有害成分名称,
            -- 基本核算相关字段
            pni.计划转移数量,
            pni.基本计量单位,
            -- 辅助核算相关字段
            pni.是否启用辅助核算,
            pni.辅助计量单位,
            pni.辅助单位每基础单位数量,
            pni.辅助数量,
            pni.创建时间,
            pni.更新时间,
            -- 危废类别信息（通过关联危废名录和类别表获取）
            c.废物类别
        FROM PICKUP_NOTICE_ITEM pni
        LEFT JOIN HAZARDOUS_WASTE_ITEM h ON pni.危废条目编号 = h.条目编号
        LEFT JOIN HAZARDOUS_WASTE_CATEGORY c ON h.废物类别编号 = c.废物类别编号
    </sql>

    <!-- 根据收运通知单号查询危废明细列表 -->
    <select id="selectByNoticeCode" resultMap="PickupNoticeItemResultMap">
        <include refid="BaseSelectSql"/>
        WHERE pni.收运通知单号 = #{noticeCode}
        ORDER BY pni.创建时间 ASC, pni.转移废物明细编号 ASC
    </select>

    <!-- 根据收运通知单号列表批量查询危废明细 -->
    <select id="selectByNoticeCodes" resultMap="PickupNoticeItemResultMap">
        <include refid="BaseSelectSql"/>
        WHERE pni.收运通知单号 IN
        <foreach collection="noticeCodes" item="noticeCode" open="(" separator="," close=")">
            #{noticeCode}
        </foreach>
        ORDER BY pni.收运通知单号 ASC, pni.创建时间 ASC
    </select>

    <!-- 根据收运通知单号删除危废明细 -->
    <delete id="deleteByNoticeCode">
        DELETE FROM PICKUP_NOTICE_ITEM
        WHERE 收运通知单号 = #{noticeCode}
    </delete>

    <!-- 根据收运通知单号列表批量删除危废明细 -->
    <delete id="deleteByNoticeCodes">
        DELETE FROM PICKUP_NOTICE_ITEM
        WHERE 收运通知单号 IN
        <foreach collection="noticeCodes" item="noticeCode" open="(" separator="," close=")">
            #{noticeCode}
        </foreach>
    </delete>

    <!-- 根据合同危废明细编号查询收运通知单明细 -->
    <select id="selectByContractWasteItemId" resultMap="PickupNoticeItemResultMap">
        <include refid="BaseSelectSql"/>
        WHERE pni.合同危废明细编号 = #{contractWasteItemId}
        ORDER BY pni.创建时间 DESC
    </select>

</mapper>

