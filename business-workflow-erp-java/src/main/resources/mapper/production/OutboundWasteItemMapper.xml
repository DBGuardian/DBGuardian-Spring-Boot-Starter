<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.erp.mapper.production.OutboundWasteItemMapper">

    <resultMap id="OutboundWasteItemResultMap" type="com.erp.entity.production.OutboundWasteItem">
        <id property="itemId" column="itemId"/>
        <result property="outboundId" column="outboundId"/>
        <result property="stockId" column="stockId"/>
        <result property="warehousingItemId" column="warehousingItemId"/>
        <result property="hazardousWasteItemId" column="hazardousWasteItemId"/>
        <result property="wasteCategory" column="wasteCategory"/>
        <result property="wasteName" column="wasteName"/>
        <result property="wasteCode" column="wasteCode"/>
        <result property="hazardFeature" column="hazardFeature"/>
        <result property="form" column="form"/>
        <result property="location" column="location"/>
        <result property="measureUnit" column="measureUnit"/>
        <result property="enableAuxiliaryAccounting" column="enableAuxiliaryAccounting"/>
        <result property="auxUnit" column="auxUnit"/>
        <result property="auxPerBase" column="auxPerBase"/>
        <result property="outboundQty" column="outboundQty"/>
        <result property="outboundAuxQty" column="outboundAuxQty"/>
        <result property="beforeStockQty" column="beforeStockQty"/>
        <result property="afterStockQty" column="afterStockQty"/>
        <result property="beforeAuxQty" column="beforeAuxQty"/>
        <result property="afterAuxQty" column="afterAuxQty"/>
        <result property="valuableWeight" column="valuableWeight"/>
        <result property="valuelessWeight" column="valuelessWeight"/>
        <result property="outboundReason" column="outboundReason"/>
        <result property="createTime" column="createTime"/>
        <result property="updateTime" column="updateTime"/>
        <result property="version" column="version"/>
    </resultMap>

    <select id="selectByOutboundId" resultMap="OutboundWasteItemResultMap">
        SELECT
            `出库危废明细编号` AS itemId,
            `出库单编号` AS outboundId,
            `库存编号` AS stockId,
            `入库危废明细编号` AS warehousingItemId,
            `危废条目编号` AS hazardousWasteItemId,
            `废物类别` AS wasteCategory,
            `废物名称` AS wasteName,
            `废物代码` AS wasteCode,
            `危险特性` AS hazardFeature,
            `废物形态` AS form,
            `库位` AS location,
            `基本计量单位` AS measureUnit,
            `是否启用辅助核算` AS enableAuxiliaryAccounting,
            `辅助计量单位` AS auxUnit,
            `辅助单位每基础单位数量` AS auxPerBase,
            `出库数量` AS outboundQty,
            `出库辅助数量` AS outboundAuxQty,
            `扣减前库存重量` AS beforeStockQty,
            `扣减后库存重量` AS afterStockQty,
            `扣减前辅助数量` AS beforeAuxQty,
            `扣减后辅助数量` AS afterAuxQty,
            `有价类重量` AS valuableWeight,
            `无价类重量` AS valuelessWeight,
            `出库原因` AS outboundReason,
            `创建时间` AS createTime,
            `更新时间` AS updateTime,
            `version` AS version
        FROM OUTBOUND_WASTE_ITEM
        WHERE `出库单编号` = #{outboundId}
        ORDER BY `出库危废明细编号`
    </select>

    <delete id="deleteByOutboundId">
        DELETE FROM OUTBOUND_WASTE_ITEM
        WHERE `出库单编号` = #{outboundId}
    </delete>

</mapper>
