<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.erp.mapper.production.PickupNoticeMapper">

    <resultMap id="PickupNoticeResultMap" type="com.erp.entity.production.PickupNotice">
        <id column="收运通知单编号" property="noticeId"/>
        <result column="收运通知单号" property="noticeCode"/>
        <result column="合同号" property="contractCode"/>
        <result column="合同待补" property="contractPending"/>
        <result column="合同补齐时间" property="contractFixTime"/>
        <result column="客户编码" property="customerId"/>
        <result column="单位名称" property="companyName"/>
        <result column="统一社会信用代码" property="creditCode"/>
        <result column="运输地址" property="transportAddress"/>
        <result column="现场联系人" property="onsiteContact"/>
        <result column="现成联系电话" property="onsitePhone"/>
        <result column="应急联系电话" property="emergencyPhone"/>
        <result column="转移交付时间" property="planTransferDate"/>
        <result column="备注" property="remark"/>
        <result column="危废详情文件" property="wasteDetailFile"/>
        <result column="产废单位二维码" property="qrCode"/>
        <result column="状态" property="status"/>
        <result column="提交时间" property="submittedAt"/>
        <result column="审核人编码" property="auditorId"/>
        <result column="审核人姓名" property="auditorName"/>
        <result column="审核时间" property="auditedAt"/>
        <result column="审核意见" property="auditOpinion"/>
        <result column="创建时间" property="createTime"/>
        <result column="创建人编码" property="creatorId"/>
        <result column="是否锁定" property="locked"/>
        <result column="锁定时间" property="lockTime"/>
        <result column="锁定人编码" property="lockUserId"/>
        <result column="锁定原因" property="lockReason"/>
        <result column="更新时间" property="updateTime"/>
    </resultMap>

    <sql id="BaseSelectSql">
        SELECT
            pn.`收运通知单编号`,
            pn.`收运通知单号`,
            pn.`合同号`,
            pn.`合同待补`,
            pn.`合同补齐时间`,
            pn.`客户编码`,
            pn.`单位名称`,
            pn.`统一社会信用代码`,
            pn.`运输地址`,
            pn.`现场联系人`,
            pn.`现成联系电话`,
            pn.`应急联系电话`,
            pn.`转移交付时间`,
            pn.`备注`,
            pn.`危废详情文件`,
            pn.`产废单位二维码`,
            pn.`状态`,
            pn.`提交时间`,
            pn.`审核人编码`,
            e.员工姓名 AS 审核人姓名,
            pn.`审核时间`,
            pn.`审核意见`,
            pn.`创建时间`,
            pn.`创建人编码`,
            pn.`是否锁定`,
            pn.`锁定时间`,
            pn.`锁定人编码`,
            pn.`锁定原因`,
            pn.`更新时间`
        FROM PICKUP_NOTICE pn
        LEFT JOIN EMPLOYEE e ON pn.审核人编码 = e.员工编码
    </sql>

    <!-- 收运通知单分页查询 -->
    <select id="selectPickupNoticePage" resultMap="PickupNoticeResultMap">
        <include refid="BaseSelectSql"/>
        <where>
            <if test="noticeCode != null and noticeCode != '' and noticeCode.trim() != ''">
                AND pn.`收运通知单号` LIKE CONCAT('%', #{noticeCode}, '%')
            </if>
            <if test="companyName != null and companyName != '' and companyName.trim() != ''">
                AND pn.`单位名称` LIKE CONCAT('%', #{companyName}, '%')
            </if>
            <if test="contractCode != null and contractCode != '' and contractCode.trim() != ''">
                AND pn.`合同号` LIKE CONCAT('%', #{contractCode}, '%')
            </if>
            <if test="customerId != null">
                AND pn.`客户编码` = #{customerId}
            </if>
            <if test="onsiteContact != null and onsiteContact != '' and onsiteContact.trim() != ''">
                AND pn.`现场联系人` LIKE CONCAT('%', #{onsiteContact}, '%')
            </if>
            <if test="onsitePhone != null and onsitePhone != '' and onsitePhone.trim() != ''">
                AND pn.`现成联系电话` LIKE CONCAT('%', #{onsitePhone}, '%')
            </if>
            <if test="status != null and status != '' and status.trim() != ''">
                AND pn.`状态` = #{status}
            </if>
            <if test="locked != null">
                AND pn.`是否锁定` = #{locked}
            </if>
            <if test="creatorId != null">
                AND pn.`创建人编码` = #{creatorId}
            </if>
            <if test="startTime != null">
                AND pn.`创建时间` &gt;= #{startTime}
            </if>
            <if test="endTime != null">
                AND pn.`创建时间` &lt;= #{endTime}
            </if>
        </where>
        <choose>
            <when test="sortField != null and sortField != ''">
                ORDER BY
                <choose>
                    <when test="sortField == 'noticeId'">pn.`收运通知单编号`</when>
                    <when test="sortField == 'noticeCode'">pn.`收运通知单号`</when>
                    <when test="sortField == 'contractCode'">pn.`合同号`</when>
                    <when test="sortField == 'companyName'">pn.`单位名称`</when>
                    <when test="sortField == 'creditCode'">pn.`统一社会信用代码`</when>
                    <when test="sortField == 'onsiteContact'">pn.`现场联系人`</when>
                    <when test="sortField == 'transportAddress'">pn.`运输地址`</when>
                    <when test="sortField == 'transferTime'">pn.`转移交付时间`</when>
                    <when test="sortField == 'status'">pn.`状态`</when>
                    <when test="sortField == 'remark'">pn.`备注`</when>
                    <when test="sortField == 'planTransferDate'">pn.`转移交付时间`</when>
                    <when test="sortField == 'submittedAt'">pn.`提交时间`</when>
                    <when test="sortField == 'auditedAt'">pn.`审核时间`</when>
                    <when test="sortField == 'auditOpinion'">pn.`审核意见`</when>
                    <when test="sortField == 'createTime'">pn.`创建时间`</when>
                    <otherwise>pn.`创建时间`</otherwise>
                </choose>
                <choose>
                    <when test="sortOrder == 'asc'">ASC</when>
                    <when test="sortOrder == 'desc'">DESC</when>
                    <otherwise>DESC</otherwise>
                </choose>
            </when>
            <otherwise>
                ORDER BY pn.`创建时间` DESC, pn.`收运通知单编号` DESC
            </otherwise>
        </choose>
    </select>

    <!-- 根据收运通知单号查询详情 -->
    <select id="selectDetailByNoticeCode" resultMap="PickupNoticeResultMap">
        <include refid="BaseSelectSql"/>
        WHERE pn.`收运通知单号` = #{noticeCode}
        LIMIT 1
    </select>

    <!-- 根据收运通知单编号查询详情 -->
    <select id="selectDetailById" resultMap="PickupNoticeResultMap">
        <include refid="BaseSelectSql"/>
        WHERE pn.`收运通知单编号` = #{noticeId}
    </select>

    <!-- 根据合同号查询收运通知单列表 -->
    <select id="selectByContractCode" resultMap="PickupNoticeResultMap">
        <include refid="BaseSelectSql"/>
        WHERE pn.`合同号` = #{contractCode}
        ORDER BY pn.`创建时间` DESC
    </select>

    <!-- 根据客户编码查询收运通知单列表 -->
    <select id="selectByCustomerId" resultMap="PickupNoticeResultMap">
        <include refid="BaseSelectSql"/>
        WHERE pn.`客户编码` = #{customerId}
        ORDER BY pn.`创建时间` DESC
    </select>

    <!-- 检查收运通知单号是否存在 -->
    <select id="countByNoticeCode" resultType="java.lang.Integer">
        SELECT COUNT(1)
        FROM PICKUP_NOTICE
        WHERE `收运通知单号` = #{noticeCode}
    </select>

    <!-- 查询指定前缀下最大的收运通知单号 -->
    <select id="selectMaxNoticeCodeByPrefix" resultType="java.lang.String">
        SELECT MAX(`收运通知单号`)
        FROM PICKUP_NOTICE
        WHERE `收运通知单号` LIKE CONCAT(#{prefix}, '%')
    </select>

    <!-- 根据危废类别编号和时间范围统计已入库量 -->
    <select id="selectInboundAmountByCategoryAndTimeRange" resultType="java.math.BigDecimal">
        SELECT COALESCE(SUM(wwi.实际收运数量), 0) AS inboundAmount
        FROM WAREHOUSING_WASTE_ITEM wwi
        INNER JOIN HAZARDOUS_WASTE_ITEM hwi ON wwi.危废条目编号 = hwi.条目编号
        WHERE hwi.废物类别编号 = #{categoryId}
          AND wwi.实际入库日期 >= #{startTime}
          AND wwi.实际入库日期 &lt;= #{endTime}
          AND wwi.实际收运数量 IS NOT NULL
          AND wwi.实际收运数量 > 0
    </select>

</mapper>

