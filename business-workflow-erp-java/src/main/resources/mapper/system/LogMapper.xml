<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.erp.mapper.system.LogMapper">

    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.erp.entity.system.Log">
        <id column="日志编号" property="logId"/>
        <result column="用户编码" property="userId"/>
        <result column="操作模块" property="operationModule"/>
        <result column="操作内容" property="operationContent"/>
        <result column="原始数据" property="oldData"/>
        <result column="新数据" property="newData"/>
        <result column="操作时间" property="operationTime"/>
        <result column="IP地址" property="ipAddress"/>
        <result column="operatorName" property="operatorName"/>
        <result column="loginAccount" property="loginAccount"/>
    </resultMap>

    <!-- 基础查询SQL -->
    <sql id="BaseSelectSql">
        SELECT
            l.日志编号,
            l.用户编码,
            l.操作模块,
            l.操作内容,
            l.原始数据,
            l.新数据,
            l.操作时间,
            l.IP地址,
            e.员工姓名 AS operatorName,
            e.登录账号 AS loginAccount
        FROM LOG l
        LEFT JOIN EMPLOYEE e ON l.用户编码 = e.员工编码
    </sql>

    <!-- 日志分页查询（全部日志） -->
    <select id="selectLogPage" resultMap="BaseResultMap">
        <include refid="BaseSelectSql"/>
        <where>
            <if test="keyword != null and keyword != ''">
                AND (
                    e.员工姓名 LIKE CONCAT('%', #{keyword}, '%')
                    OR e.登录账号 LIKE CONCAT('%', #{keyword}, '%')
                    OR l.操作模块 LIKE CONCAT('%', #{keyword}, '%')
                    OR l.操作内容 LIKE CONCAT('%', #{keyword}, '%')
                    OR CAST(l.日志编号 AS CHAR) LIKE CONCAT('%', #{keyword}, '%')
                )
            </if>
            <if test="logType != null and logType != ''">
                <choose>
                    <when test="logType == '操作日志'">
                        AND l.操作模块 != 'login' AND (l.操作内容 LIKE '%新增%' OR l.操作内容 LIKE '%编辑%' OR l.操作内容 LIKE '%删除%' OR l.操作内容 LIKE '%审核%' OR l.操作内容 LIKE '%导出%')
                    </when>
                    <when test="logType == '数据变更'">
                        AND l.原始数据 IS NOT NULL AND l.新数据 IS NOT NULL
                    </when>
                    <when test="logType == '登录'">
                        AND l.操作模块 = 'login'
                    </when>
                </choose>
            </if>
            <if test="status != null and status != ''">
                <choose>
                    <when test="status == 'success'">
                        AND (l.操作内容 LIKE '%成功%' OR l.操作内容 NOT LIKE '%失败%' AND l.操作内容 NOT LIKE '%错误%')
                    </when>
                    <when test="status == 'failed'">
                        AND (l.操作内容 LIKE '%失败%' OR l.操作内容 LIKE '%错误%')
                    </when>
                </choose>
            </if>
            <if test="module != null and module != ''">
                AND l.操作模块 LIKE CONCAT('%', #{module}, '%')
            </if>
            <if test="ipAddress != null and ipAddress != ''">
                AND l.IP地址 LIKE CONCAT('%', #{ipAddress}, '%')
            </if>
            <if test="startTime != null">
                AND l.操作时间 &gt;= #{startTime}
            </if>
            <if test="endTime != null">
                AND l.操作时间 &lt;= #{endTime}
            </if>
        </where>
        ORDER BY
        <choose>
            <when test="sortField != null and sortField != ''">
                <choose>
                    <when test="sortField == 'operationTime'">l.操作时间</when>
                    <when test="sortField == 'logId'">l.日志编号</when>
                    <when test="sortField == 'operationModule'">l.操作模块</when>
                    <otherwise>l.操作时间</otherwise>
                </choose>
                <choose>
                    <when test="sortOrder != null and sortOrder == 'asc'">ASC</when>
                    <otherwise>DESC</otherwise>
                </choose>
            </when>
            <otherwise>
                l.操作时间 DESC
            </otherwise>
        </choose>
    </select>

    <!-- 操作日志分页查询 -->
    <select id="selectOperationLogPage" resultMap="BaseResultMap">
        <include refid="BaseSelectSql"/>
        <where>
            AND l.操作模块 != 'login'
            AND (l.操作内容 LIKE '%新增%' OR l.操作内容 LIKE '%编辑%' OR l.操作内容 LIKE '%删除%' OR l.操作内容 LIKE '%审核%' OR l.操作内容 LIKE '%导出%')
            <if test="keyword != null and keyword != ''">
                AND (
                    e.员工姓名 LIKE CONCAT('%', #{keyword}, '%')
                    OR e.登录账号 LIKE CONCAT('%', #{keyword}, '%')
                    OR l.操作模块 LIKE CONCAT('%', #{keyword}, '%')
                    OR l.操作内容 LIKE CONCAT('%', #{keyword}, '%')
                )
            </if>
            <if test="module != null and module != ''">
                AND l.操作模块 LIKE CONCAT('%', #{module}, '%')
            </if>
            <if test="operationTypes != null and operationTypes.size() > 0">
                AND (
                <foreach collection="operationTypes" item="opType" separator=" OR ">
                    l.操作内容 LIKE CONCAT('%', #{opType}, '%')
                </foreach>
                )
            </if>
            <if test="userIds != null and userIds.size() > 0">
                AND l.用户编码 IN
                <foreach collection="userIds" item="userId" open="(" separator="," close=")">
                    #{userId}
                </foreach>
            </if>
            <if test="ipAddress != null and ipAddress != ''">
                AND l.IP地址 LIKE CONCAT('%', #{ipAddress}, '%')
            </if>
            <if test="startTime != null">
                AND l.操作时间 &gt;= #{startTime}
            </if>
            <if test="endTime != null">
                AND l.操作时间 &lt;= #{endTime}
            </if>
        </where>
        ORDER BY
        <choose>
            <when test="sortField != null and sortField != ''">
                <choose>
                    <when test="sortField == 'operationTime'">l.操作时间</when>
                    <when test="sortField == 'logId'">l.日志编号</when>
                    <otherwise>l.操作时间</otherwise>
                </choose>
                <choose>
                    <when test="sortOrder != null and sortOrder == 'asc'">ASC</when>
                    <otherwise>DESC</otherwise>
                </choose>
            </when>
            <otherwise>
                l.操作时间 DESC
            </otherwise>
        </choose>
    </select>

    <!-- 数据变更日志分页查询 -->
    <select id="selectDataChangeLogPage" resultMap="BaseResultMap">
        <include refid="BaseSelectSql"/>
        <where>
            AND l.原始数据 IS NOT NULL AND l.新数据 IS NOT NULL
            AND TRIM(l.原始数据) != '' AND TRIM(l.新数据) != ''
            <if test="keyword != null and keyword != ''">
                AND (
                    e.员工姓名 LIKE CONCAT('%', #{keyword}, '%')
                    OR e.登录账号 LIKE CONCAT('%', #{keyword}, '%')
                    OR l.操作模块 LIKE CONCAT('%', #{keyword}, '%')
                    OR l.操作内容 LIKE CONCAT('%', #{keyword}, '%')
                )
            </if>
            <if test="module != null and module != ''">
                AND l.操作模块 LIKE CONCAT('%', #{module}, '%')
            </if>
            <if test="changeTypes != null and changeTypes.size() > 0">
                AND (
                <foreach collection="changeTypes" item="changeType" separator=" OR ">
                    l.操作内容 LIKE CONCAT('%', #{changeType}, '%')
                </foreach>
                )
            </if>
            <if test="userIds != null and userIds.size() > 0">
                AND l.用户编码 IN
                <foreach collection="userIds" item="userId" open="(" separator="," close=")">
                    #{userId}
                </foreach>
            </if>
            <if test="startTime != null">
                AND l.操作时间 &gt;= #{startTime}
            </if>
            <if test="endTime != null">
                AND l.操作时间 &lt;= #{endTime}
            </if>
        </where>
        ORDER BY
        <choose>
            <when test="sortField != null and sortField != ''">
                <choose>
                    <when test="sortField == 'operationTime'">l.操作时间</when>
                    <when test="sortField == 'logId'">l.日志编号</when>
                    <otherwise>l.操作时间</otherwise>
                </choose>
                <choose>
                    <when test="sortOrder != null and sortOrder == 'asc'">ASC</when>
                    <otherwise>DESC</otherwise>
                </choose>
            </when>
            <otherwise>
                l.操作时间 DESC
            </otherwise>
        </choose>
    </select>

    <!-- 登录日志分页查询 -->
    <select id="selectLoginLogPage" resultMap="BaseResultMap">
        <include refid="BaseSelectSql"/>
        <where>
            AND l.操作模块 = 'login'
            <if test="keyword != null and keyword != ''">
                AND (
                    e.员工姓名 LIKE CONCAT('%', #{keyword}, '%')
                    OR e.登录账号 LIKE CONCAT('%', #{keyword}, '%')
                )
            </if>
            <if test="loginResult != null and loginResult != ''">
                <choose>
                    <when test="loginResult == '成功'">
                        AND l.操作内容 LIKE '%成功%'
                    </when>
                    <when test="loginResult == '失败'">
                        AND (l.操作内容 LIKE '%失败%' OR l.操作内容 LIKE '%错误%')
                    </when>
                </choose>
            </if>
            <if test="ipAddress != null and ipAddress != ''">
                AND l.IP地址 LIKE CONCAT('%', #{ipAddress}, '%')
            </if>
            <if test="startTime != null">
                AND l.操作时间 &gt;= #{startTime}
            </if>
            <if test="endTime != null">
                AND l.操作时间 &lt;= #{endTime}
            </if>
        </where>
        ORDER BY
        <choose>
            <when test="sortField != null and sortField != ''">
                <choose>
                    <when test="sortField == 'operationTime'">l.操作时间</when>
                    <when test="sortField == 'logId'">l.日志编号</when>
                    <otherwise>l.操作时间</otherwise>
                </choose>
                <choose>
                    <when test="sortOrder != null and sortOrder == 'asc'">ASC</when>
                    <otherwise>DESC</otherwise>
                </choose>
            </when>
            <otherwise>
                l.操作时间 DESC
            </otherwise>
        </choose>
    </select>

    <!-- 根据日志编号查询日志详情 -->
    <select id="selectLogDetail" resultMap="BaseResultMap">
        <include refid="BaseSelectSql"/>
        WHERE l.日志编号 = #{logId}
    </select>

    <!-- 根据条件查询日志列表（用于导出） -->
    <select id="selectLogsForExport" resultMap="BaseResultMap">
        <include refid="BaseSelectSql"/>
        <where>
            <if test="logIds != null and logIds.size() > 0">
                AND l.日志编号 IN
                <foreach collection="logIds" item="logId" open="(" separator="," close=")">
                    #{logId}
                </foreach>
            </if>
            <if test="keyword != null and keyword != ''">
                AND (
                    e.员工姓名 LIKE CONCAT('%', #{keyword}, '%')
                    OR e.登录账号 LIKE CONCAT('%', #{keyword}, '%')
                    OR l.操作模块 LIKE CONCAT('%', #{keyword}, '%')
                    OR l.操作内容 LIKE CONCAT('%', #{keyword}, '%')
                )
            </if>
            <if test="logType != null and logType != ''">
                <choose>
                    <when test="logType == '操作日志'">
                        AND l.操作模块 != 'login' AND (l.操作内容 LIKE '%新增%' OR l.操作内容 LIKE '%编辑%' OR l.操作内容 LIKE '%删除%' OR l.操作内容 LIKE '%审核%' OR l.操作内容 LIKE '%导出%')
                    </when>
                    <when test="logType == '数据变更'">
                        AND l.原始数据 IS NOT NULL AND l.新数据 IS NOT NULL
                    </when>
                    <when test="logType == '登录'">
                        AND l.操作模块 = 'login'
                    </when>
                </choose>
            </if>
            <if test="status != null and status != ''">
                <choose>
                    <when test="status == 'success'">
                        AND (l.操作内容 LIKE '%成功%' OR l.操作内容 NOT LIKE '%失败%' AND l.操作内容 NOT LIKE '%错误%')
                    </when>
                    <when test="status == 'failed'">
                        AND (l.操作内容 LIKE '%失败%' OR l.操作内容 LIKE '%错误%')
                    </when>
                </choose>
            </if>
            <if test="module != null and module != ''">
                AND l.操作模块 LIKE CONCAT('%', #{module}, '%')
            </if>
            <if test="ipAddress != null and ipAddress != ''">
                AND l.IP地址 LIKE CONCAT('%', #{ipAddress}, '%')
            </if>
            <if test="startTime != null">
                AND l.操作时间 &gt;= #{startTime}
            </if>
            <if test="endTime != null">
                AND l.操作时间 &lt;= #{endTime}
            </if>
        </where>
        ORDER BY l.操作时间 DESC
    </select>

</mapper>






