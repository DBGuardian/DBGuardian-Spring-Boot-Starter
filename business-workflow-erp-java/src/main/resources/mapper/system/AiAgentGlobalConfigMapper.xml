<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.erp.mapper.system.AiAgentGlobalConfigMapper">

    <resultMap id="BaseResultMap" type="com.erp.entity.system.AiAgentGlobalConfig">
        <result property="maxRequestsPerSecond" column="每秒最大请求数"/>
        <result property="maxTextLengthPerRequest" column="每次请求最大文本长度"/>
        <result property="maxParagraphsPerRequest" column="每次请求最大段落数"/>
        <result property="maxConversationMessages" column="单会话最大消息条数"/>
        <result property="maxConversationChars" column="单会话累计字符上限"/>
    </resultMap>

    <sql id="Base_Column_List">
        每秒最大请求数,
        每次请求最大文本长度,
        每次请求最大段落数,
        单会话最大消息条数,
        单会话累计字符上限
    </sql>

    <!-- 查询全局唯一配置（全表仅一条记录） -->
    <select id="selectSingleton" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM AI_AGENT_GLOBAL_CONFIG
        LIMIT 1
    </select>

    <!-- 更新全局唯一配置（不依赖主键，直接更新整表） -->
    <update id="updateSingleton">
        UPDATE AI_AGENT_GLOBAL_CONFIG
        SET
            每秒最大请求数 = #{maxRequestsPerSecond},
            每次请求最大文本长度 = #{maxTextLengthPerRequest},
            每次请求最大段落数 = #{maxParagraphsPerRequest},
            单会话最大消息条数 = #{maxConversationMessages},
            单会话累计字符上限 = #{maxConversationChars}
    </update>

</mapper>



