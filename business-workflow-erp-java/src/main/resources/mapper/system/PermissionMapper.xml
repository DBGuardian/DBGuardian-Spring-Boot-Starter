<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.erp.mapper.system.PermissionMapper">

    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.erp.entity.system.Permission">
        <id column="权限编号" property="permissionId"/>
        <result column="权限名称" property="permissionName"/>
        <result column="权限描述" property="permissionDescription"/>
        <result column="权限类型编号" property="permissionTypeId"/>
        <result column="权限编码" property="permissionCode"/>
        <result column="页面模式" property="pageMode"/>
        <result column="父权限编号" property="parentPermissionId"/>
    </resultMap>

    <!-- 权限响应结果映射（包含父权限名称） -->
    <resultMap id="PermissionResponseResultMap" type="com.erp.controller.system.dto.PermissionResponse">
        <id column="权限编号" property="permissionId"/>
        <result column="权限名称" property="permissionName"/>
        <result column="权限描述" property="permissionDescription"/>
        <result column="权限类型编号" property="permissionTypeId"/>
        <result column="权限编码" property="permissionCode"/>
        <result column="页面模式" property="pageMode"/>
        <result column="父权限编号" property="parentPermissionId"/>
        <result column="父权限名称" property="parentPermissionName"/>
    </resultMap>

    <sql id="BaseSelectSql">
        SELECT
            p.权限编号,
            p.权限名称,
            p.权限描述,
            p.权限类型编号,
            p.权限编码,
            p.页面模式,
            p.父权限编号,
            pp.权限名称 AS 父权限名称
        FROM PERMISSION p
        LEFT JOIN PERMISSION pp ON p.父权限编号 = pp.权限编号
    </sql>

    <!-- 分页查询权限列表（包含父权限名称） -->
    <select id="selectPermissionPage" resultMap="PermissionResponseResultMap">
        <include refid="BaseSelectSql"/>
        <where>
            <if test="params.permissionTypeIds != null and params.permissionTypeIds.size() > 0">
                AND p.权限类型编号 IN
                <foreach collection="params.permissionTypeIds" item="permissionTypeId" open="(" close=")" separator=",">
                    #{permissionTypeId}
                </foreach>
            </if>
            <if test="params.permissionTypeId != null">
                AND p.权限类型编号 = #{params.permissionTypeId}
            </if>
            <if test="params.pageMode != null and params.pageMode.trim() != ''">
                AND p.页面模式 = #{params.pageMode}
            </if>
            <if test="params.permissionName != null and params.permissionName.trim() != ''">
                AND p.权限名称 LIKE CONCAT('%', #{params.permissionName}, '%')
            </if>
            <if test="params.permissionDescription != null and params.permissionDescription.trim() != ''">
                AND p.权限描述 LIKE CONCAT('%', #{params.permissionDescription}, '%')
            </if>
            <if test="params.parentPermissionName != null and params.parentPermissionName.trim() != ''">
                AND pp.权限名称 LIKE CONCAT('%', #{params.parentPermissionName}, '%')
            </if>
        </where>
        ORDER BY p.权限编号 ASC
    </select>

    <!-- 根据条件查询权限列表（包含父权限名称） -->
    <select id="selectByCondition" resultMap="PermissionResponseResultMap">
        <include refid="BaseSelectSql"/>
        <where>
            <if test="params.typeId != null">
                AND p.权限类型编号 = #{params.typeId}
            </if>
            <if test="params.keyword != null and params.keyword.trim() != ''">
                AND (p.权限名称 LIKE CONCAT('%', #{params.keyword}, '%')
                     OR p.权限编码 LIKE CONCAT('%', #{params.keyword}, '%'))
            </if>
        </where>
        ORDER BY p.权限编号 ASC
    </select>

    <!-- 查询所有权限（用于构建权限树） -->
    <select id="selectAllPermissions" resultMap="BaseResultMap">
        SELECT
            权限编号,
            权限名称,
            权限描述,
            权限类型编号,
            权限编码,
            页面模式,
            父权限编号
        FROM PERMISSION
        ORDER BY 权限编号 ASC
    </select>

    <!-- 批量更新权限的父权限ID -->
    <update id="batchUpdateParentPermissionId">
        UPDATE PERMISSION
        SET 父权限编号 = #{parentPermissionId},
            更新时间 = NOW()
        WHERE 权限编号 IN
        <foreach collection="permissionIds" item="permissionId" open="(" close=")" separator=",">
            #{permissionId}
        </foreach>
    </update>

    <!-- 更新单个权限的父权限ID -->
    <update id="updateParentPermissionId">
        UPDATE PERMISSION
        SET 父权限编号 = #{parentPermissionId},
            更新时间 = NOW()
        WHERE 权限编号 = #{permissionId}
    </update>

    <!-- 查询指定权限被哪些角色使用 -->
    <select id="selectRoleIdsByPermissionId" resultType="java.lang.Integer">
        SELECT DISTINCT 角色编号
        FROM ROLE_PERMISSION
        WHERE 权限编号 = #{permissionId}
        ORDER BY 角色编号
    </select>

    <!-- 查询指定权限被哪些员工直接使用（员工级权限覆盖） -->
    <select id="selectEmployeeIdsByPermissionId" resultType="java.lang.Integer">
        SELECT DISTINCT 员工编码
        FROM EMPLOYEE_PERMISSION
        WHERE 权限编号 = #{permissionId}
        ORDER BY 员工编码
    </select>

    <!-- 批量清空指定父权限的所有子权限的父权限编号 -->
    <update id="clearChildParentPermissionIds">
        UPDATE PERMISSION
        SET 父权限编号 = NULL,
            更新时间 = NOW()
        WHERE 父权限编号 = #{parentPermissionId}
    </update>

</mapper>
