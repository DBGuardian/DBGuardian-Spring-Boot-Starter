<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.erp.mapper.system.AiAgentConfigMapper">

    <resultMap id="BaseResultMap" type="com.erp.entity.system.AiAgentConfig">
        <id property="agentId" column="智能体编号"/>
        <result property="agentCode" column="智能体编码"/>
        <result property="agentName" column="智能体名称"/>
        <result property="provider" column="提供方"/>
        <result property="baseUrl" column="接口地址"/>
        <result property="modelName" column="模型名称"/>
        <result property="apiKeyCipher" column="API密钥密文"/>
        <result property="status" column="启用状态"/>
        <result property="isDefault" column="默认智能体标记"/>
        <result property="sortOrder" column="排序号"/>
        <result property="remark" column="备注"/>
        <result property="createUserId" column="创建人编码"/>
        <result property="updateUserId" column="更新人编码"/>
        <result property="createTime" column="创建时间"/>
        <result property="version" column="version"/>
        <result property="updateTime" column="更新时间"/>
    </resultMap>

    <sql id="Base_Column_List">
        智能体编号,
        智能体编码,
        智能体名称,
        提供方,
        接口地址,
        模型名称,
        API密钥密文,
        启用状态,
        默认智能体标记,
        排序号,
        备注,
        创建人编码,
        更新人编码,
        创建时间,
        更新时间,
        version
    </sql>

    <select id="selectAllOrderBySort" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM AI_AGENT_CONFIG
        ORDER BY 排序号 ASC, 智能体编号 DESC
    </select>

    <update id="clearDefaultFlag">
        UPDATE AI_AGENT_CONFIG
        SET 默认智能体标记 = 0
    </update>

    <update id="setDefaultAgent">
        UPDATE AI_AGENT_CONFIG
        SET 默认智能体标记 = 1
        WHERE 智能体编号 = #{agentId}
    </update>

</mapper>





