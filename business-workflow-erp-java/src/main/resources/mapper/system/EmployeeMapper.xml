<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.erp.mapper.system.EmployeeMapper">

    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.erp.entity.system.Employee">
        <id column="员工编码" property="employeeId"/>
        <result column="员工姓名" property="employeeName"/>
        <result column="部门" property="department"/>
        <result column="岗位" property="jobTitle"/>
        <result column="联系方式" property="phone"/>
        <result column="邮箱" property="email"/>
        <result column="登录账号" property="loginAccount"/>
        <result column="密码" property="password"/>
        <result column="角色" property="role"/>
        <result column="员工状态" property="employeeStatus"/>
        <result column="创建时间" property="createTime"/>
        <result column="更新时间" property="updateTime"/>
        <result column="备注" property="remark"/>
        <result column="身份证号码" property="idCard"/>
        <result column="身份证正面文件ID" property="idCardFrontFileId"/>
        <result column="身份证反面文件ID" property="idCardBackFileId"/>
    </resultMap>

    <!-- 根据登录账号查询员工 -->
    <select id="selectByLoginAccount" resultMap="BaseResultMap">
        SELECT
            员工编码,
            员工姓名,
            部门,
            岗位,
            联系方式,
            邮箱,
            登录账号,
            密码,
            角色,
            员工状态,
            创建时间,
            更新时间,
            备注,
            身份证号码,
            身份证正面文件ID,
            身份证反面文件ID
        FROM EMPLOYEE
        WHERE 登录账号 = #{loginAccount}
    </select>

    <!-- 根据邮箱查询员工 -->
    <select id="selectByEmail" resultMap="BaseResultMap">
        SELECT
            员工编码,
            员工姓名,
            部门,
            岗位,
            联系方式,
            邮箱,
            登录账号,
            密码,
            角色,
            员工状态,
            创建时间,
            更新时间,
            备注,
            身份证号码,
            身份证正面文件ID,
            身份证反面文件ID
        FROM EMPLOYEE
        WHERE 邮箱 = #{email}
    </select>

    <!-- 根据手机号查询员工 -->
    <select id="selectByPhone" resultMap="BaseResultMap">
        SELECT
            员工编码,
            员工姓名,
            部门,
            岗位,
            联系方式,
            邮箱,
            登录账号,
            密码,
            角色,
            员工状态,
            创建时间,
            更新时间,
            备注,
            身份证号码,
            身份证正面文件ID,
            身份证反面文件ID
        FROM EMPLOYEE
        WHERE 联系方式 = #{phone}
    </select>

    <!-- 分页查询员工列表 -->
    <select id="selectPageList" resultMap="BaseResultMap">
        SELECT
            员工编码,
            员工姓名,
            部门,
            岗位,
            联系方式,
            邮箱,
            登录账号,
            密码,
            角色,
            员工状态,
            创建时间,
            更新时间,
            备注,
            身份证号码,
            身份证正面文件ID,
            身份证反面文件ID
        FROM EMPLOYEE
        <where>
            <if test="employeeName != null and employeeName != ''">
                AND 员工姓名 LIKE CONCAT('%', #{employeeName}, '%')
            </if>
            <if test="department != null and department != ''">
                AND 部门 LIKE CONCAT('%', #{department}, '%')
            </if>
            <if test="jobTitle != null and jobTitle != ''">
                AND 岗位 LIKE CONCAT('%', #{jobTitle}, '%')
            </if>
            <if test="phone != null and phone != ''">
                AND 联系方式 LIKE CONCAT('%', #{phone}, '%')
            </if>
            <if test="loginAccount != null and loginAccount != ''">
                AND 登录账号 LIKE CONCAT('%', #{loginAccount}, '%')
            </if>
            <if test="employeeStatus != null and employeeStatus != ''">
                AND 员工状态 = #{employeeStatus}
            </if>
        </where>
        <choose>
            <when test="sortField != null and sortField != ''">
                ORDER BY
                <choose>
                    <when test="sortField == 'employeeId'">员工编码</when>
                    <when test="sortField == 'employeeName'">员工姓名</when>
                    <when test="sortField == 'loginAccount'">登录账号</when>
                    <when test="sortField == 'department'">部门</when>
                    <when test="sortField == 'jobTitle'">岗位</when>
                    <when test="sortField == 'phone'">联系方式</when>
                    <when test="sortField == 'role'">角色</when>
                    <when test="sortField == 'employeeStatus'">员工状态</when>
                    <when test="sortField == 'createTime'">创建时间</when>
                    <when test="sortField == 'updateTime'">更新时间</when>
                    <otherwise>创建时间</otherwise>
                </choose>
                <choose>
                    <when test="sortOrder == 'asc'">ASC</when>
                    <when test="sortOrder == 'desc'">DESC</when>
                    <otherwise>DESC</otherwise>
                </choose>
            </when>
            <otherwise>
                ORDER BY 创建时间 DESC
            </otherwise>
        </choose>
    </select>

</mapper>





