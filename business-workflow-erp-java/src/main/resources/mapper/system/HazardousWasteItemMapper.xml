<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.erp.mapper.system.HazardousWasteItemMapper">

    <resultMap id="HazardousWasteItemResultMap" type="com.erp.entity.system.HazardousWasteItem">
        <id property="itemId" column="条目编号"/>
        <result property="categoryId" column="废物类别编号"/>
        <result property="industrySource" column="行业来源"/>
        <result property="wasteCode" column="废物代码"/>
        <result property="wasteName" column="危险废物"/>
        <result property="hazardCharacteristic" column="危险特性"/>
        <result property="available" column="是否可用"/>
        <result property="creatorId" column="创建人编码"/>
        <result property="creatorName" column="creator_name"/>
        <result property="wasteCategory" column="waste_category_code"/>
        <result property="wasteCategoryName" column="waste_category_name"/>
        <result property="version" column="version"/>
    </resultMap>

    <sql id="BaseSelectSql">
        SELECT
            h.条目编号,
            h.废物类别编号,
            h.行业来源,
            h.废物代码,
            h.危险废物,
            h.危险特性,
            h.是否可用,
            h.创建人编码,
            e.员工姓名 AS creator_name,
            c.废物类别 AS waste_category_code,
            c.废物类别名称 AS waste_category_name
        FROM HAZARDOUS_WASTE_ITEM h
        LEFT JOIN HAZARDOUS_WASTE_CATEGORY c ON h.废物类别编号 = c.废物类别编号
        LEFT JOIN EMPLOYEE e ON h.创建人编码 = e.员工编码
    </sql>

    <sql id="CommonWhereSql">
        <where>
            <!-- 数据范围过滤：仅查看自己创建的危废条目 -->
            <if test="creatorFilter != null">
                AND h.创建人编码 = #{creatorFilter}
            </if>
            <if test="keyword != null">
                AND (
                    h.废物代码 LIKE CONCAT('%', #{keyword}, '%')
                    OR h.危险废物 LIKE CONCAT('%', #{keyword}, '%')
                    OR c.废物类别 LIKE CONCAT('%', #{keyword}, '%')
                    OR c.废物类别名称 LIKE CONCAT('%', #{keyword}, '%')
                )
            </if>
            <if test="hazardCharacteristic != null">
                AND h.危险特性 LIKE CONCAT('%', #{hazardCharacteristic}, '%')
            </if>
            <if test="wasteCategory != null">
                AND c.废物类别 LIKE CONCAT('%', #{wasteCategory}, '%')
            </if>
            <if test="wasteCategoryName != null">
                AND c.废物类别名称 LIKE CONCAT('%', #{wasteCategoryName}, '%')
            </if>
            <if test="industrySource != null">
                AND h.行业来源 LIKE CONCAT('%', #{industrySource}, '%')
            </if>
            <if test="wasteCode != null">
                AND h.废物代码 LIKE CONCAT('%', #{wasteCode}, '%')
            </if>
            <if test="wasteName != null">
                AND h.危险废物 LIKE CONCAT('%', #{wasteName}, '%')
            </if>
            <if test="available != null">
                AND h.是否可用 = #{available}
            </if>
        </where>
    </sql>

    <select id="selectWasteItemPage" resultMap="HazardousWasteItemResultMap">
        <include refid="BaseSelectSql"/>
        <include refid="CommonWhereSql"/>
        <choose>
            <when test="orderBy != null and orderBy != ''">
                ORDER BY
                <choose>
                    <when test="orderBy == 'itemId'">h.条目编号</when>
                    <when test="orderBy == 'wasteCategory'">c.废物类别</when>
                    <when test="orderBy == 'wasteCategoryName'">c.废物类别名称</when>
                    <when test="orderBy == 'industrySource'">h.行业来源</when>
                    <when test="orderBy == 'wasteCode'">h.废物代码</when>
                    <when test="orderBy == 'wasteName'">h.危险废物</when>
                    <when test="orderBy == 'hazardCharacteristic'">h.危险特性</when>
                    <when test="orderBy == 'available'">h.是否可用</when>
                    <otherwise>h.条目编号</otherwise>
                </choose>
                <choose>
                    <when test="orderDirection == 'asc'">ASC</when>
                    <when test="orderDirection == 'desc'">DESC</when>
                    <otherwise>DESC</otherwise>
                </choose>
                <if test="orderBy != 'itemId'">
                    , h.条目编号 DESC
                </if>
            </when>
            <otherwise>
                ORDER BY h.条目编号 DESC
            </otherwise>
        </choose>
    </select>

    <select id="selectWasteItemList" resultMap="HazardousWasteItemResultMap">
        <include refid="BaseSelectSql"/>
        <include refid="CommonWhereSql"/>
        <choose>
            <when test="orderBy != null and orderBy != ''">
                ORDER BY
                <choose>
                    <when test="orderBy == 'itemId'">h.条目编号</when>
                    <when test="orderBy == 'wasteCategory'">c.废物类别</when>
                    <when test="orderBy == 'wasteCategoryName'">c.废物类别名称</when>
                    <when test="orderBy == 'industrySource'">h.行业来源</when>
                    <when test="orderBy == 'wasteCode'">h.废物代码</when>
                    <when test="orderBy == 'wasteName'">h.危险废物</when>
                    <when test="orderBy == 'hazardCharacteristic'">h.危险特性</when>
                    <when test="orderBy == 'available'">h.是否可用</when>
                    <otherwise>h.条目编号</otherwise>
                </choose>
                <choose>
                    <when test="orderDirection == 'asc'">ASC</when>
                    <when test="orderDirection == 'desc'">DESC</when>
                    <otherwise>DESC</otherwise>
                </choose>
                <if test="orderBy != 'itemId'">
                    , h.条目编号 DESC
                </if>
            </when>
            <otherwise>
                ORDER BY h.条目编号 DESC
            </otherwise>
        </choose>
    </select>

    <select id="selectDetailById" resultMap="HazardousWasteItemResultMap">
        <include refid="BaseSelectSql"/>
        WHERE h.条目编号 = #{itemId}
        LIMIT 1
    </select>

    <select id="selectByWasteCode" resultMap="HazardousWasteItemResultMap">
        <include refid="BaseSelectSql"/>
        WHERE h.废物代码 = #{wasteCode}
        LIMIT 1
    </select>

    <select id="selectExistingWasteCodes" resultType="java.lang.String">
        SELECT 废物代码
        FROM HAZARDOUS_WASTE_ITEM
        WHERE 废物代码 IN
        <foreach collection="codes" item="code" open="(" separator="," close=")">
            #{code}
        </foreach>
    </select>

    <insert id="insertBatch">
        INSERT INTO HAZARDOUS_WASTE_ITEM
        (
            行业来源,
            废物代码,
            危险废物,
            危险特性,
            是否可用,
            废物类别编号,
            创建人编码
        )
        VALUES
        <foreach collection="items" item="item" separator=",">
            (
                #{item.industrySource},
                #{item.wasteCode},
                #{item.wasteName},
                #{item.hazardCharacteristic},
                #{item.available},
                #{item.categoryId},
                #{item.creatorId}
            )
        </foreach>
    </insert>

    <select id="selectReferenceStats" resultType="com.erp.mapper.system.domain.HazardousWasteReferenceStat">
        SELECT
            h.条目编号 AS itemId,
            COALESCE(q_stats.customer_count, 0) AS customerCount,
            COALESCE(q_stats.quotation_count, 0) AS quotationCount,
            COALESCE(w.warehousing_count, 0) AS warehousingCount,
            COALESCE(s.stock_count, 0) AS stockCount
        FROM HAZARDOUS_WASTE_ITEM h
        LEFT JOIN (
            SELECT
                qwi.危废条目编号 AS item_id,
                COUNT(DISTINCT q.客户编码) AS customer_count,
                COUNT(DISTINCT qi.报价单编号) AS quotation_count
            FROM QUOTATION_WASTE_ITEM qwi
            INNER JOIN QUOTATION_ITEM qi ON qwi.报价条目编号 = qi.报价条目编号
            INNER JOIN QUOTATION q ON qi.报价单编号 = q.报价单编号
            WHERE qwi.危废条目编号 IS NOT NULL
              AND qwi.危废条目编号 IN
              <foreach collection="itemIds" item="id" open="(" separator="," close=")">
                  #{id}
              </foreach>
            GROUP BY qwi.危废条目编号
        ) q_stats ON h.条目编号 = q_stats.item_id
        LEFT JOIN (
            SELECT 危废条目编号 AS item_id, COUNT(1) AS warehousing_count
            FROM WAREHOUSING_WASTE_ITEM
            WHERE 危废条目编号 IS NOT NULL
              AND 危废条目编号 IN
              <foreach collection="itemIds" item="id" open="(" separator="," close=")">
                  #{id}
              </foreach>
            GROUP BY 危废条目编号
        ) w ON h.条目编号 = w.item_id
        LEFT JOIN (
            SELECT 危废条目编号 AS item_id, COUNT(1) AS stock_count
            FROM STOCK
            WHERE 危废条目编号 IS NOT NULL
              AND 危废条目编号 IN
              <foreach collection="itemIds" item="id" open="(" separator="," close=")">
                  #{id}
              </foreach>
            GROUP BY 危废条目编号
        ) s ON h.条目编号 = s.item_id
        WHERE h.条目编号 IN
        <foreach collection="itemIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

    <insert id="insertWithCategory" parameterType="com.erp.entity.system.HazardousWasteItem">
        INSERT INTO HAZARDOUS_WASTE_ITEM
        (
            行业来源,
            废物代码,
            危险废物,
            危险特性,
            是否可用,
            废物类别编号,
            创建人编码
        )
        VALUES
        (
            #{industrySource},
            #{wasteCode},
            #{wasteName},
            #{hazardCharacteristic},
            #{available},
            #{categoryId},
            #{creatorId}
        )
    </insert>

    <update id="updateByIdWithCategory" parameterType="com.erp.entity.system.HazardousWasteItem">
        UPDATE HAZARDOUS_WASTE_ITEM
        SET
            行业来源 = #{industrySource},
            废物代码 = #{wasteCode},
            危险废物 = #{wasteName},
            危险特性 = #{hazardCharacteristic},
            是否可用 = #{available},
            废物类别编号 = #{categoryId}
        WHERE 条目编号 = #{itemId}
    </update>

    <select id="countByCategoryId" resultType="java.lang.Long">
        SELECT COUNT(1)
        FROM HAZARDOUS_WASTE_ITEM
        WHERE 废物类别编号 = #{categoryId}
    </select>

    <select id="selectWasteCategoryList" resultType="java.lang.String">
        SELECT DISTINCT c.废物类别
        FROM HAZARDOUS_WASTE_CATEGORY c
        INNER JOIN HAZARDOUS_WASTE_ITEM h ON c.废物类别编号 = h.废物类别编号
        WHERE h.是否可用 = 1
        ORDER BY c.废物类别
    </select>

    <select id="selectDetailByIds" resultMap="HazardousWasteItemResultMap">
        <include refid="BaseSelectSql"/>
        WHERE h.条目编号 IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </select>

    <delete id="deleteBatch">
        DELETE FROM HAZARDOUS_WASTE_ITEM
        WHERE 条目编号 IN
        <foreach collection="ids" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

</mapper>

