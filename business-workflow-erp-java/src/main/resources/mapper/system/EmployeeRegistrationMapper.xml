<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.erp.mapper.system.EmployeeRegistrationMapper">

    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.erp.entity.system.EmployeeRegistration">
        <id column="注册编号" property="registrationId"/>
        <result column="员工姓名" property="employeeName"/>
        <result column="部门" property="department"/>
        <result column="岗位" property="jobTitle"/>
        <result column="手机号码" property="phone"/>
        <result column="邮箱" property="email"/>
        <result column="身份证号码" property="idCard"/>
        <result column="身份证正面文件编号" property="idCardFrontFileId"/>
        <result column="身份证反面文件编号" property="idCardBackFileId"/>
        <result column="登录账号" property="loginAccount"/>
        <result column="密码" property="password"/>
        <result column="审核状态" property="auditStatus"/>
        <result column="权限分配状态" property="permissionStatus"/>
        <result column="提交时间" property="submitTime"/>
        <result column="审核时间" property="auditTime"/>
        <result column="审核人编码" property="auditorId"/>
        <result column="审核意见" property="auditOpinion"/>
        <result column="分配人编码" property="assignerId"/>
        <result column="分配完成时间" property="assignCompleteTime"/>
        <result column="转员工编码" property="employeeId"/>
        <result column="创建时间" property="createTime"/>
        <result column="更新时间" property="updateTime"/>
    </resultMap>

    <!-- 根据登录账号查询注册信息 -->
    <select id="selectByLoginAccount" resultMap="BaseResultMap">
        SELECT
            注册编号,
            员工姓名,
            部门,
            岗位,
            手机号码,
            邮箱,
            身份证号码,
            身份证正面文件编号,
            身份证反面文件编号,
            登录账号,
            密码,
            审核状态,
            权限分配状态,
            提交时间,
            审核时间,
            审核人编码,
            审核意见,
            分配人编码,
            分配完成时间,
            转员工编码
        FROM EMPLOYEE_REGISTRATION
        WHERE 登录账号 = #{loginAccount}
    </select>

    <!-- 根据手机号码查询注册信息 -->
    <select id="selectByPhone" resultMap="BaseResultMap">
        SELECT
            注册编号,
            员工姓名,
            部门,
            岗位,
            手机号码,
            邮箱,
            身份证号码,
            身份证正面文件编号,
            身份证反面文件编号,
            登录账号,
            密码,
            审核状态,
            权限分配状态,
            提交时间,
            审核时间,
            审核人编码,
            审核意见,
            分配人编码,
            分配完成时间,
            转员工编码
        FROM EMPLOYEE_REGISTRATION
        WHERE 手机号码 = #{phone}
    </select>

    <!-- 分页查询员工注册信息 -->
    <select id="selectPageList" resultMap="BaseResultMap">
        SELECT
            注册编号,
            员工姓名,
            部门,
            岗位,
            手机号码,
            邮箱,
            身份证号码,
            身份证正面文件编号,
            身份证反面文件编号,
            登录账号,
            密码,
            审核状态,
            权限分配状态,
            提交时间,
            审核时间,
            审核人编码,
            审核意见,
            分配人编码,
            分配完成时间,
            转员工编码
        FROM EMPLOYEE_REGISTRATION
        <where>
            <if test="employeeName != null and employeeName != ''">
                AND 员工姓名 LIKE CONCAT('%', #{employeeName}, '%')
            </if>
            <if test="department != null and department != ''">
                AND 部门 LIKE CONCAT('%', #{department}, '%')
            </if>
            <if test="jobTitle != null and jobTitle != ''">
                AND 岗位 LIKE CONCAT('%', #{jobTitle}, '%')
            </if>
            <if test="phone != null and phone != ''">
                AND 手机号码 LIKE CONCAT('%', #{phone}, '%')
            </if>
            <if test="loginAccount != null and loginAccount != ''">
                AND 登录账号 LIKE CONCAT('%', #{loginAccount}, '%')
            </if>
            <if test="auditStatus != null and auditStatus != ''">
                AND 审核状态 = #{auditStatus}
            </if>
            <if test="permissionStatus != null and permissionStatus != ''">
                AND 权限分配状态 = #{permissionStatus}
            </if>
        </where>
        ORDER BY 提交时间 DESC
    </select>

</mapper>



