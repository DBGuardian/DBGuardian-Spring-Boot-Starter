<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.erp.mapper.system.EmailChannelConfigMapper">

    <resultMap id="BaseResultMap" type="com.erp.entity.system.EmailChannelConfig">
        <id property="configId" column="配置编号"/>
        <result property="displayName" column="显示名称"/>
        <result property="fromAddress" column="默认发件地址"/>
        <result property="replyTo" column="回复地址"/>
        <result property="smtpHost" column="SMTP_HOST"/>
        <result property="smtpPort" column="SMTP_PORT"/>
        <result property="authMethod" column="认证方式"/>
        <result property="username" column="登录账号"/>
        <result property="passwordCipher" column="授权码密文"/>
        <result property="encryption" column="加密策略"/>
        <result property="status" column="启用状态"/>
        <result property="maxPerHour" column="每小时最大发送量"/>
        <result property="maxPerDay" column="每日最大发送量"/>
        <result property="updatedBy" column="更新人编码"/>
        <result property="createTime" column="创建时间"/>
        <result property="updateTime" column="更新时间"/>
        <result property="lastSelfTestTime" column="最后自检时间"/>
    </resultMap>

    <sql id="Base_Column_List">
        配置编号,
        显示名称,
        默认发件地址,
        回复地址,
        SMTP_HOST,
        SMTP_PORT,
        认证方式,
        登录账号,
        授权码密文,
        加密策略,
        启用状态,
        每小时最大发送量,
        每日最大发送量,
        更新人编码,
        创建时间,
        更新时间,
        最后自检时间
    </sql>

    <select id="selectLatest" resultMap="BaseResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM EMAIL_CHANNEL_CONFIG
        ORDER BY 更新时间 DESC, 配置编号 DESC
        LIMIT 1
    </select>

</mapper>






























