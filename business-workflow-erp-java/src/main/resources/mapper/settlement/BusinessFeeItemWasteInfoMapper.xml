<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.erp.mapper.settlement.BusinessFeeItemWasteInfoMapper">

    <resultMap id="BusinessFeeItemWasteInfoResultMap" type="com.erp.entity.settlement.BusinessFeeItemWasteInfo">
        <id property="wasteInfoId" column="危废信息编号"/>
        <result property="itemSeq" column="明细序号"/>
        <result property="rowOrder" column="行内顺序"/>
        <result property="sourceWasteDetailIds" column="来源危废明细编号" typeHandler="com.baomidou.mybatisplus.extension.handlers.JacksonTypeHandler"/>
        <result property="wasteCategory" column="废物类别"/>
        <result property="wasteCode" column="废物代码"/>
        <result property="wasteName" column="废物名称"/>
        <result property="createTime" column="创建时间"/>
        <result property="updateTime" column="更新时间"/>
        <result property="version" column="version"/>
    </resultMap>

    <sql id="BaseColumns">
        `危废信息编号`,
        `明细序号`,
        `行内顺序`,
        `来源危废明细编号`,
        `废物类别`,
        `废物代码`,
        `废物名称`,
        `创建时间`,
        `更新时间`,
        `version`
    </sql>

    <select id="selectByItemSeq" resultMap="BusinessFeeItemWasteInfoResultMap">
        SELECT
        <include refid="BaseColumns"/>
        FROM BUSINESS_FEE_ITEM_WASTE_INFO
        WHERE `明细序号` = #{itemSeq}
        ORDER BY `行内顺序` ASC
    </select>

    <select id="selectByItemSeqs" resultMap="BusinessFeeItemWasteInfoResultMap">
        SELECT
        <include refid="BaseColumns"/>
        FROM BUSINESS_FEE_ITEM_WASTE_INFO
        WHERE `明细序号` IN
        <foreach collection="itemSeqs" item="seq" open="(" separator="," close=")">
            #{seq}
        </foreach>
        ORDER BY `明细序号` ASC, `行内顺序` ASC
    </select>

</mapper>
