<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.erp.mapper.finance.SettlementReferenceMapper">

    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.erp.entity.settlement.SettlementReference">
        <id column="关联记录编号" property="referenceId"/>
        <result column="结算单编号" property="settlementId"/>
        <result column="关联来源类型" property="sourceType"/>
        <result column="关联来源单号" property="sourceCode"/>
        <result column="创建时间" property="createTime"/>
        <result column="更新时间" property="updateTime"/>
    </resultMap>

    <!-- 根据结算单ID查询关联的入库记录编码列表 -->
    <select id="selectWarehousingCodesBySettlementId" resultType="java.lang.String">
        SELECT DISTINCT `关联来源单号`
        FROM SETTLEMENT_REFERENCE
        WHERE `结算单编号` = #{settlementId}
        AND `关联来源类型` = 'WAREHOUSING'
        ORDER BY `关联来源单号` ASC
    </select>

    <!-- 根据结算单ID查询关联的运输记录编码列表 -->
    <select id="selectTransportCodesBySettlementId" resultType="java.lang.String">
        SELECT DISTINCT `关联来源单号`
        FROM SETTLEMENT_REFERENCE
        WHERE `结算单编号` = #{settlementId}
        AND `关联来源类型` = 'TRANSPORT'
        ORDER BY `关联来源单号` ASC
    </select>

</mapper>
