<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.erp.mapper.common.FileMapper">

    <!-- 结果映射 -->
    <resultMap id="BaseResultMap" type="com.erp.entity.common.File">
        <id column="文件编号" property="fileId"/>
        <result column="文件名称" property="fileName"/>
        <result column="文件类型" property="fileType"/>
        <result column="文件大小" property="fileSize"/>
        <result column="存储类型" property="storageType"/>
        <result column="本地存储路径" property="localPath"/>
        <result column="存储桶名称" property="bucketName"/>
        <result column="对象键" property="objectKey"/>
        <result column="存储区域" property="region"/>
        <result column="访问URL" property="fileUrl"/>
        <result column="访问密钥ID" property="accessKeyId"/>
        <result column="业务模块" property="businessModule"/>
        <result column="关联业务ID" property="businessId"/>
        <result column="关联业务类型" property="businessType"/>
        <result column="文件MD5" property="fileMd5"/>
        <result column="文件SHA256" property="fileSha256"/>
        <result column="上传时间" property="uploadTime"/>
        <result column="上传人编码" property="uploaderId"/>
        <result column="文件状态" property="fileStatus"/>
        <result column="删除时间" property="deleteTime"/>
        <result column="创建时间" property="createTime"/>
        <result column="更新时间" property="updateTime"/>
        <result column="备注" property="remark"/>
    </resultMap>

    <!-- 根据业务类型和业务ID查询文件列表 -->
    <select id="selectByBusinessTypeAndId" resultMap="BaseResultMap">
        SELECT
            文件编号,
            文件名称,
            文件类型,
            文件大小,
            存储类型,
            本地存储路径,
            存储桶名称,
            对象键,
            存储区域,
            访问URL,
            访问密钥ID,
            业务模块,
            关联业务ID,
            关联业务类型,
            文件MD5,
            文件SHA256,
            上传时间,
            上传人编码,
            文件状态,
            删除时间,
            创建时间,
            更新时间,
            备注
        FROM FILE
        WHERE 关联业务类型 = #{businessType}
          AND 关联业务ID = #{businessId}
        ORDER BY 创建时间 DESC
    </select>

    <!-- 根据业务类型和业务ID删除文件 -->
    <delete id="deleteByBusinessTypeAndId">
        DELETE FROM FILE
        WHERE 关联业务类型 = #{businessType}
          AND 关联业务ID = #{businessId}
    </delete>

    <!-- 根据业务类型与业务ID集合批量查询文件 -->
    <select id="selectByBusinessTypeAndIds" resultMap="BaseResultMap">
        SELECT
            文件编号,
            文件名称,
            文件类型,
            文件大小,
            存储类型,
            本地存储路径,
            存储桶名称,
            对象键,
            存储区域,
            访问URL,
            访问密钥ID,
            业务模块,
            关联业务ID,
            关联业务类型,
            文件MD5,
            文件SHA256,
            上传时间,
            上传人编码,
            文件状态,
            删除时间,
            创建时间,
            更新时间,
            备注
        FROM FILE
        WHERE 关联业务类型 = #{businessType}
        <if test="businessIds != null and businessIds.size() > 0">
            AND 关联业务ID IN
            <foreach item="id" collection="businessIds" open="(" separator="," close=")">
                #{id}
            </foreach>
        </if>
        <if test="businessIds == null or businessIds.size() == 0">
            AND 1 = 0
        </if>
        ORDER BY 创建时间 DESC
    </select>

</mapper>

