<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.erp.mapper.finance.InvoiceMapper">

    <!-- 根据发票号码查询发票 -->
    <select id="selectByInvoiceNumber" resultType="com.erp.entity.finance.Invoice">
        SELECT
            发票编号                  AS invoiceId,
            发票类型                  AS invoiceType,
            发票形式                  AS invoiceForm,
            发票性质                  AS invoiceNature,
            发票状态                  AS invoiceStatus,
            金额                      AS amount,
            税额                      AS taxAmount,
            价税合计                  AS totalAmount,
            价税合计大写              AS totalAmountInChinese,
            不含税金额                AS taxExcludedAmount,
            发票号码                  AS invoiceNumber,
            发票代码                  AS invoiceCode,
            开票日期                  AS invoiceDate,
            购买方名称                AS buyerName,
            购买方统一社会信用代码     AS buyerCreditCode,
            购买方地址                AS buyerAddress,
            购买方电话                AS buyerPhone,
            购买方开户行              AS buyerBankName,
            购买方账号                AS buyerBankAccount,
            销售方名称                AS sellerName,
            销售方统一社会信用代码     AS sellerCreditCode,
            销售方地址                AS sellerAddress,
            销售方电话                AS sellerPhone,
            销售方开户行              AS sellerBankName,
            销售方账号                AS sellerBankAccount,
            录入发票明细              AS recordDetails,
            发票扫描件PDF文件编号      AS pdfFileId,
            发票扫描件图片文件编号     AS imageFileId,
            开票人名称                AS issuerName,
            备注                      AS remark,
            是否锁定                  AS isLocked,
            锁定时间                  AS lockTime,
            锁定人编码                AS lockerId,
            锁定原因                  AS lockReason,
            创建人编码                AS creatorId,
            创建时间                  AS createTime,
            更新时间                  AS updateTime,
            version                   AS version
        FROM INVOICE
        WHERE 发票号码 = #{invoiceNumber}
    </select>

    <!-- 插入发票明细 -->
    <insert id="insertItem" parameterType="com.erp.entity.finance.InvoiceItem" useGeneratedKeys="true" keyProperty="itemId">
        INSERT INTO INVOICE_ITEM (
            发票编号, 商品名称, 规格型号, 单位, 数量, 单价, 金额, 税率, 商品税额, 税收分类编码, 含税金额, 备注
        ) VALUES (
            #{invoiceId}, #{productName}, #{specification}, #{unit}, #{quantity}, 
            #{unitPrice}, #{amount}, #{taxRate}, #{productTaxAmount}, #{taxClassificationCode}, #{taxIncludedAmount}, #{remark}
        )
    </insert>

    <!-- 根据发票编号查询发票明细列表 -->
    <select id="selectItemsByInvoiceId" resultType="com.erp.entity.finance.InvoiceItem">
        SELECT 
            明细编号              AS itemId,
            发票编号              AS invoiceId,
            商品名称              AS productName,
            规格型号              AS specification,
            单位                  AS unit,
            数量                  AS quantity,
            单价                  AS unitPrice,
            金额                  AS amount,
            税率                  AS taxRate,
            商品税额              AS productTaxAmount,
            税收分类编码          AS taxClassificationCode,
            含税金额              AS taxIncludedAmount,
            备注                  AS remark
        FROM INVOICE_ITEM 
        WHERE 发票编号 = #{invoiceId} 
        ORDER BY 明细编号
    </select>

    <!-- 根据发票编号删除发票明细 -->
    <delete id="deleteItemsByInvoiceId">
        DELETE FROM INVOICE_ITEM WHERE 发票编号 = #{invoiceId}
    </delete>

    <!-- 根据明细编号删除发票明细 -->
    <delete id="deleteItemById">
        DELETE FROM INVOICE_ITEM WHERE 明细编号 = #{itemId}
    </delete>

    <!-- 更新发票明细 -->
    <update id="updateItem" parameterType="com.erp.entity.finance.InvoiceItem">
        UPDATE INVOICE_ITEM SET
            商品名称 = #{productName},
            规格型号 = #{specification},
            单位 = #{unit},
            数量 = #{quantity},
            单价 = #{unitPrice},
            金额 = #{amount},
            税率 = #{taxRate},
            商品税额 = #{productTaxAmount},
            税收分类编码 = #{taxClassificationCode},
            含税金额 = #{taxIncludedAmount},
            备注 = #{remark}
        WHERE 明细编号 = #{itemId}
    </update>

    <!-- 发票分页查询结果映射（包含明细列表） -->
    <resultMap id="InvoicePageResultMap" type="com.erp.controller.finance.dto.InvoicePageResponse">
        <!-- 发票基本信息 -->
        <id column="发票编号" property="invoiceId"/>
        <result column="发票类型" property="invoiceType"/>
        <result column="发票形式" property="invoiceForm"/>
        <result column="发票性质" property="invoiceNature"/>
        <result column="发票状态" property="invoiceStatus"/>
        <result column="金额" property="amount"/>
        <result column="税额" property="taxAmount"/>
        <result column="价税合计" property="totalAmount"/>
        <result column="价税合计大写" property="totalAmountInChinese"/>
        <result column="不含税金额" property="taxExcludedAmount"/>
        <result column="发票号码" property="invoiceNumber"/>
        <result column="发票代码" property="invoiceCode"/>
        <result column="开票日期" property="invoiceDate"/>
        <result column="购买方名称" property="buyerName"/>
        <result column="购买方统一社会信用代码" property="buyerCreditCode"/>
        <result column="购买方地址" property="buyerAddress"/>
        <result column="购买方电话" property="buyerPhone"/>
        <result column="购买方开户行" property="buyerBankName"/>
        <result column="购买方账号" property="buyerBankAccount"/>
        <result column="销售方名称" property="sellerName"/>
        <result column="销售方统一社会信用代码" property="sellerCreditCode"/>
        <result column="销售方地址" property="sellerAddress"/>
        <result column="销售方电话" property="sellerPhone"/>
        <result column="销售方开户行" property="sellerBankName"/>
        <result column="销售方账号" property="sellerBankAccount"/>
        <result column="录入发票明细" property="recordDetails"/>
        <result column="发票扫描件PDF文件编号" property="pdfFileId"/>
        <result column="发票扫描件图片文件编号" property="imageFileId"/>
        <result column="开票人名称" property="issuerName"/>
        <result column="备注" property="remark"/>
        <result column="是否锁定" property="isLocked"/>
        <result column="锁定时间" property="lockTime"/>
        <result column="锁定人编码" property="lockerId"/>
        <result column="锁定原因" property="lockReason"/>
        <result column="创建人编码" property="creatorId"/>
        <result column="创建人名称" property="creatorName"/>
        <result column="创建时间" property="createTime"/>
        <result column="更新时间" property="updateTime"/>
        
        <!-- 发票明细列表 -->
        <collection property="details" ofType="com.erp.entity.finance.InvoiceItem">
            <id column="明细编号" property="itemId"/>
            <result column="明细_发票编号" property="invoiceId"/>
            <result column="商品名称" property="productName"/>
            <result column="规格型号" property="specification"/>
            <result column="单位" property="unit"/>
            <result column="数量" property="quantity"/>
            <result column="单价" property="unitPrice"/>
            <result column="明细_金额" property="amount"/>
            <result column="税率" property="taxRate"/>
            <result column="商品税额" property="productTaxAmount"/>
            <result column="税收分类编码" property="taxClassificationCode"/>
            <result column="含税金额" property="taxIncludedAmount"/>
            <result column="明细_备注" property="remark"/>
        </collection>
    </resultMap>

    <!-- 发票分页查询（连表查询，包含明细） -->
    <!-- 使用子查询先对主表进行分页，然后再LEFT JOIN明细表，确保分页准确 -->
    <select id="selectInvoicePage" resultMap="InvoicePageResultMap">
        SELECT
            i.发票编号,
            i.发票类型,
            i.发票形式,
            i.发票性质,
            i.发票状态,
            i.金额,
            i.税额,
            i.价税合计,
            i.价税合计大写,
            i.不含税金额,
            i.发票号码,
            i.发票代码,
            i.开票日期,
            i.购买方名称,
            i.购买方统一社会信用代码,
            i.购买方地址,
            i.购买方电话,
            i.购买方开户行,
            i.购买方账号,
            i.销售方名称,
            i.销售方统一社会信用代码,
            i.销售方地址,
            i.销售方电话,
            i.销售方开户行,
            i.销售方账号,
            i.录入发票明细,
            i.发票扫描件PDF文件编号,
            i.发票扫描件图片文件编号,
            i.开票人名称,
            i.备注,
            i.是否锁定,
            i.锁定时间,
            i.锁定人编码,
            i.锁定原因,
            i.创建人编码,
            i.创建时间,
            i.更新时间,
            ii.明细编号,
            ii.发票编号 AS 明细_发票编号,
            ii.商品名称,
            ii.规格型号,
            ii.单位,
            ii.数量,
            ii.单价,
            ii.金额 AS 明细_金额,
            ii.税率,
            ii.商品税额,
            ii.税收分类编码,
            ii.含税金额,
            ii.备注 AS 明细_备注,
            e.员工姓名 AS 创建人名称
        FROM (
            SELECT
                发票编号,
                发票类型,
                发票形式,
                发票性质,
                发票状态,
                金额,
                税额,
                价税合计,
                价税合计大写,
                不含税金额,
                发票号码,
                发票代码,
                开票日期,
                购买方名称,
                购买方统一社会信用代码,
                购买方地址,
                购买方电话,
                购买方开户行,
                购买方账号,
                销售方名称,
                销售方统一社会信用代码,
                销售方地址,
                销售方电话,
                销售方开户行,
                销售方账号,
                录入发票明细,
                发票扫描件PDF文件编号,
                发票扫描件图片文件编号,
                开票人名称,
                备注,
                是否锁定,
                锁定时间,
                锁定人编码,
                锁定原因,
                创建人编码,
                创建时间,
                更新时间
            FROM INVOICE
            <where>
                <!-- 必须指定发票状态：进项发票/销项发票 -->
                <if test="req.invoiceStatus != null and req.invoiceStatus != ''">
                    AND 发票状态 = #{req.invoiceStatus}
                </if>

                <!-- 发票类型筛选 -->
                <if test="req.invoiceType != null and req.invoiceType != ''">
                    AND 发票类型 = #{req.invoiceType}
                </if>

                <!-- 发票形式筛选 -->
                <if test="req.invoiceForm != null and req.invoiceForm != ''">
                    AND 发票形式 = #{req.invoiceForm}
                </if>

                <!-- 发票性质筛选 -->
                <if test="req.invoiceNature != null and req.invoiceNature != ''">
                    AND 发票性质 = #{req.invoiceNature}
                </if>

                <!-- 开票日期范围筛选 -->
                <if test="req.invoiceDateStart != null and req.invoiceDateStart != ''">
                    AND 开票日期 &gt;= CONCAT(#{req.invoiceDateStart}, ' 00:00:00')
                </if>
                
                <if test="req.invoiceDateEnd != null and req.invoiceDateEnd != ''">
                    AND 开票日期 &lt;= CONCAT(#{req.invoiceDateEnd}, ' 23:59:59')
                </if>

                <!-- 发票号码模糊查询 -->
                <if test="req.invoiceNumber != null and req.invoiceNumber != ''">
                    AND 发票号码 LIKE CONCAT('%', #{req.invoiceNumber}, '%')
                </if>

                <!-- 销售方名称模糊查询 -->
                <if test="req.sellerName != null and req.sellerName != ''">
                    AND 销售方名称 LIKE CONCAT('%', #{req.sellerName}, '%')
                </if>

                <!-- 销售方统一社会信用代码模糊查询 -->
                <if test="req.sellerCreditCode != null and req.sellerCreditCode != ''">
                    AND 销售方统一社会信用代码 LIKE CONCAT('%', #{req.sellerCreditCode}, '%')
                </if>

                <!-- 购买方名称模糊查询 -->
                <if test="req.buyerName != null and req.buyerName != ''">
                    AND 购买方名称 LIKE CONCAT('%', #{req.buyerName}, '%')
                </if>

                <!-- 购买方统一社会信用代码模糊查询 -->
                <if test="req.buyerCreditCode != null and req.buyerCreditCode != ''">
                    AND 购买方统一社会信用代码 LIKE CONCAT('%', #{req.buyerCreditCode}, '%')
                </if>

                <!-- 数据范围过滤：仅查看自己创建的发票 -->
                <if test="req.creatorFilter != null">
                    AND 创建人编码 = #{req.creatorFilter}
                </if>
            </where>
            <choose>
                <when test="req.sortField != null and req.sortField != '' and 
                            (req.sortField == 'invoiceId' or req.sortField == 'invoiceNumber' or req.sortField == 'invoiceCode' or 
                             req.sortField == 'invoiceType' or req.sortField == 'invoiceForm' or req.sortField == 'invoiceNature' or 
                             req.sortField == 'invoiceStatus' or req.sortField == 'amount' or req.sortField == 'taxAmount' or 
                             req.sortField == 'totalAmount' or req.sortField == 'invoiceDate' or req.sortField == 'buyerName' or 
                             req.sortField == 'sellerName' or req.sortField == 'issuerName' or req.sortField == 'status' or req.sortField == 'createTime' or 
                             req.sortField == 'updateTime')">
                    ORDER BY
                    <choose>
                        <when test="req.sortField == 'invoiceId'">
                            发票编号
                        </when>
                        <when test="req.sortField == 'invoiceNumber'">
                            发票号码
                        </when>
                        <when test="req.sortField == 'invoiceCode'">
                            发票代码
                        </when>
                        <when test="req.sortField == 'invoiceType'">
                            发票类型
                        </when>
                        <when test="req.sortField == 'invoiceForm'">
                            发票形式
                        </when>
                        <when test="req.sortField == 'invoiceNature'">
                            发票性质
                        </when>
                        <when test="req.sortField == 'invoiceStatus'">
                            发票状态
                        </when>
                        <when test="req.sortField == 'amount'">
                            金额
                        </when>
                        <when test="req.sortField == 'taxAmount'">
                            税额
                        </when>
                        <when test="req.sortField == 'totalAmount'">
                            价税合计
                        </when>
                        <when test="req.sortField == 'invoiceDate'">
                            开票日期
                        </when>
                        <when test="req.sortField == 'buyerName'">
                            购买方名称
                        </when>
                        <when test="req.sortField == 'sellerName'">
                            销售方名称
                        </when>
                        <when test="req.sortField == 'issuerName'">
                            开票人名称
                        </when>
                        <when test="req.sortField == 'createTime'">
                            创建时间
                        </when>
                        <when test="req.sortField == 'updateTime'">
                            更新时间
                        </when>
                    </choose>
                    <choose>
                        <when test="req.sortOrder != null and req.sortOrder == 'desc'">
                            DESC
                        </when>
                        <when test="req.sortOrder != null and req.sortOrder == 'asc'">
                            ASC
                        </when>
                        <otherwise>
                            DESC
                        </otherwise>
                    </choose>
                    , 发票编号 DESC
                </when>
                <otherwise>
                    ORDER BY 开票日期 DESC, 发票编号 DESC
                </otherwise>
            </choose>
        ) i
        LEFT JOIN INVOICE_ITEM ii ON i.发票编号 = ii.发票编号
        LEFT JOIN EMPLOYEE e ON i.创建人编码 = e.员工编码
        ORDER BY i.发票编号, COALESCE(ii.明细编号, 0) ASC
    </select>

    <!-- 发票详情结果映射（包含明细列表） -->
    <resultMap id="InvoiceDetailResultMap" type="com.erp.controller.finance.dto.InvoiceDetailDTO">
        <!-- 发票基本信息 -->
        <id column="发票编号" property="invoiceId"/>
        <result column="发票类型" property="invoiceType"/>
        <result column="发票形式" property="invoiceForm"/>
        <result column="发票性质" property="invoiceNature"/>
        <result column="发票状态" property="invoiceStatus"/>
        <result column="发票号码" property="invoiceNumber"/>
        <result column="发票代码" property="invoiceCode"/>
        <result column="开票日期" property="invoiceDate" jdbcType="TIMESTAMP"/>
        <result column="金额" property="amount" jdbcType="DECIMAL"/>
        <result column="税额" property="taxAmount" jdbcType="DECIMAL"/>
        <result column="价税合计" property="totalAmount" jdbcType="DECIMAL"/>
        <result column="价税合计大写" property="totalAmountInChinese"/>
        <result column="不含税金额" property="taxExcludedAmount" jdbcType="DECIMAL"/>
        <result column="录入发票明细" property="recordDetails"/>
        <result column="备注" property="remark"/>
        <result column="开票人名称" property="issuerName"/>
        <result column="发票扫描件PDF文件编号" property="pdfFileId"/>
        <result column="发票扫描件图片文件编号" property="imageFileId"/>
        <result column="是否锁定" property="isLocked"/>
        <result column="锁定时间" property="lockTime" jdbcType="TIMESTAMP"/>
        <result column="锁定人编码" property="lockerId"/>
        <result column="锁定原因" property="lockReason"/>
        <result column="创建人编码" property="creatorId"/>
        <result column="创建人名称" property="creatorName"/>
        
        <!-- 购买方信息 -->
        <result column="购买方名称" property="buyerName"/>
        <result column="购买方统一社会信用代码" property="buyerCreditCode"/>
        <result column="购买方地址" property="buyerAddress"/>
        <result column="购买方电话" property="buyerPhone"/>
        <result column="购买方开户行" property="buyerBankName"/>
        <result column="购买方账号" property="buyerBankAccount"/>
        
        <!-- 销售方信息 -->
        <result column="销售方名称" property="sellerName"/>
        <result column="销售方统一社会信用代码" property="sellerCreditCode"/>
        <result column="销售方地址" property="sellerAddress"/>
        <result column="销售方电话" property="sellerPhone"/>
        <result column="销售方开户行" property="sellerBankName"/>
        <result column="销售方账号" property="sellerBankAccount"/>
        
        <!-- 发票明细列表 -->
        <collection property="details" ofType="com.erp.entity.finance.InvoiceItem">
            <id column="明细编号" property="itemId"/>
            <result column="明细_发票编号" property="invoiceId"/>
            <result column="商品名称" property="productName"/>
            <result column="规格型号" property="specification"/>
            <result column="单位" property="unit"/>
            <result column="数量" property="quantity"/>
            <result column="单价" property="unitPrice"/>
            <result column="明细_金额" property="amount"/>
            <result column="税率" property="taxRate"/>
            <result column="商品税额" property="productTaxAmount"/>
            <result column="税收分类编码" property="taxClassificationCode"/>
            <result column="含税金额" property="taxIncludedAmount"/>
            <result column="明细_备注" property="remark"/>
        </collection>
    </resultMap>

    <!-- 根据发票ID查询发票详情（连表查询，包含明细） -->
    <select id="selectInvoiceDetailWithItems" resultMap="InvoiceDetailResultMap">
        SELECT
            i.发票编号,
            i.发票类型,
            i.发票形式,
            i.发票性质,
            i.发票状态,
            i.发票号码,
            i.发票代码,
            i.开票日期,
            i.金额,
            i.税额,
            i.价税合计,
            i.价税合计大写,
            i.不含税金额,
            i.录入发票明细,
            i.备注,
            i.开票人名称,
            i.发票扫描件PDF文件编号,
            i.发票扫描件图片文件编号,
            i.是否锁定,
            i.锁定时间,
            i.锁定人编码,
            i.锁定原因,
            i.创建人编码,
            i.购买方名称,
            i.购买方统一社会信用代码,
            i.购买方地址,
            i.购买方电话,
            i.购买方开户行,
            i.购买方账号,
            i.销售方名称,
            i.销售方统一社会信用代码,
            i.销售方地址,
            i.销售方电话,
            i.销售方开户行,
            i.销售方账号,
            ii.明细编号,
            ii.发票编号 AS 明细_发票编号,
            ii.商品名称,
            ii.规格型号,
            ii.单位,
            ii.数量,
            ii.单价,
            ii.金额 AS 明细_金额,
            ii.税率,
            ii.商品税额,
            ii.税收分类编码,
            ii.含税金额,
            ii.备注 AS 明细_备注,
            e.员工姓名 AS 创建人名称
        FROM INVOICE i
        LEFT JOIN INVOICE_ITEM ii ON i.发票编号 = ii.发票编号
        LEFT JOIN EMPLOYEE e ON i.创建人编码 = e.员工编码
        WHERE i.发票编号 = #{invoiceId}
        ORDER BY COALESCE(ii.明细编号, 0) ASC
    </select>

  <!-- 根据发票ID列表查询发票明细 -->
  <select id="selectItemsByInvoiceIds" resultType="com.erp.entity.finance.InvoiceItem">
    SELECT
      明细编号              AS itemId,
      发票编号              AS invoiceId,
      商品名称              AS productName,
      规格型号              AS specification,
      单位                  AS unit,
      数量                  AS quantity,
      单价                  AS unitPrice,
      金额                  AS amount,
      税率                  AS taxRate,
      商品税额              AS productTaxAmount,
      税收分类编码          AS taxClassificationCode,
      含税金额              AS taxIncludedAmount,
      备注                  AS remark,
      创建时间              AS createTime,
      更新时间              AS updateTime,
      version               AS version
    FROM INVOICE_ITEM
    WHERE 发票编号 IN
    <foreach item="invoiceId" collection="invoiceIds" open="(" separator="," close=")">
      #{invoiceId}
    </foreach>
    ORDER BY 发票编号, 明细编号
  </select>

  <!-- 查询发票的关联记录 -->
  <select id="selectInvoiceAssociations" resultType="java.util.Map">
    SELECT
      sir.关系编号 AS relationId,
      sir.结算单编号 AS settlementId,
      s.结算单单号 AS settlementCode,
      sir.开票通知单编号 AS noticeId,
      sir.发票编号 AS invoiceId,
      sir.关联金额 AS relAmount,
      sir.关联类型 AS associateType,
      sir.关联时间 AS associateTime,
      sir.备注 AS remark,
      sir.status AS status,
      c.合同编号 AS contractId,
      c.合同号 AS contractNo,
      c.甲方名称 AS contractName,
      c.客户编码 AS customerId
    FROM SETTLEMENT_INVOICE_REL sir
    LEFT JOIN SETTLEMENT s ON sir.结算单编号 = s.结算单编号
    LEFT JOIN CONTRACT c ON s.合同编号 = c.合同编号
    WHERE sir.发票编号 = #{invoiceId}
    ORDER BY sir.关联时间 DESC
  </select>

</mapper>

