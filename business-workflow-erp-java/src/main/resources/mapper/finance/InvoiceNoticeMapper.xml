<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.erp.mapper.finance.InvoiceNoticeMapper">

    <!-- 根据前缀查询最大通知单号 -->
    <select id="selectMaxNoticeNoByPrefix" parameterType="string" resultType="string">
        SELECT MAX(开票通知单号) FROM INVOICE_NOTICE WHERE 开票通知单号 LIKE CONCAT(#{prefix}, '%')
    </select>

    <!-- 根据通知单号统计数量 -->
    <select id="countByNoticeNo" parameterType="string" resultType="int">
        SELECT COUNT(1) FROM INVOICE_NOTICE WHERE 开票通知单号 = #{noticeNo}
    </select>

    <!-- 开票通知单详情结果映射（包含发票列表和客户信息） -->
    <resultMap id="InvoiceNoticeDetailResultMap" type="com.erp.controller.finance.dto.InvoiceNoticeDetailResponse">
        <!-- 通知单基本信息 -->
        <id column="开票通知单编号" property="noticeId"/>
        <result column="开票通知单号" property="noticeNo"/>
        <result column="合同编号" property="contractId"/>
        <result column="合同号" property="contractNo"/>
        <result column="合同名称" property="contractName"/>
        <result column="客户编码" property="customerId"/>
        <result column="客户名称" property="customerName"/>
        <result column="结算单编号" property="mainSettlementId"/>
        <!-- 结算单常规字段 -->
        <result column="settlementCode" property="settlementCode"/>
        <result column="settlementType" property="settlementType"/>
        <result column="settlementPeriodStart" property="settlementPeriodStart"/>
        <result column="settlementPeriodEnd" property="settlementPeriodEnd"/>
        <result column="settlementAmount" property="settlementAmount"/>
        <result column="receivedAmount" property="receivedAmount"/>
        <result column="settlementStatus" property="settlementStatus"/>
        <result column="settlementCreateTime" property="settlementCreateTime"/>
        <result column="settlementCreatorName" property="settlementCreatorName"/>
        <result column="已绑定结算摘要" property="boundSettlementSummary"/>
        <result column="开票类型" property="invoiceType"/>
        <result column="备注" property="remark"/>
        <result column="状态" property="status"/>
        <result column="申请人编码" property="applicantId"/>
        <result column="申请人姓名" property="applicantName"/>
        <result column="审批人编码" property="approverId"/>
        <result column="审批人姓名" property="approverName"/>
        <result column="审批意见" property="approvalOpinion"/>
        <result column="办理人编码" property="handlerId"/>
        <result column="办理人姓名" property="handlerName"/>
        <result column="已开票张数" property="invoiceCount"/>
        <result column="已开票价税合计" property="totalAmount"/>
        <result column="开票完成时间" property="issuedAt"/>
        <result column="创建时间" property="createTime"/>
        <result column="创建人编码" property="createUserId"/>
        <result column="更新时间" property="updateTime"/>
        <result column="更新人编码" property="updateUserId"/>
        <result column="version" property="version"/>
        <result column="创建时间" property="createdAt"/>
        <result column="更新时间" property="updatedAt"/>
        <result column="locked" property="locked"/>
        <result column="lockReason" property="lockReason"/>
        <!-- 客户详细信息 -->
        <result column="企业名称" property="enterpriseName"/>
        <result column="统一社会信用代码" property="creditCode"/>
        <result column="地址" property="address"/>
        <result column="电话" property="phone"/>
        <result column="法定代表人" property="legalRepresentative"/>
        <result column="联系人" property="contactPerson"/>
        <result column="联系电话" property="contactPhone"/>
        <!-- 关联的发票列表 -->
        <collection property="invoices" ofType="com.erp.controller.finance.dto.InvoiceNoticeInvoiceDTO">
            <id column="明细编号" property="detailId"/>
            <result column="明细_开票通知单编号" property="noticeId"/>
            <result column="发票编号" property="invoiceId"/>
            <result column="发票号码" property="invoiceNumber"/>
            <result column="发票代码" property="invoiceCode"/>
            <result column="开票日期" property="invoiceDate"/>
            <result column="发票类型" property="invoiceType"/>
            <result column="发票形式" property="invoiceForm"/>
            <result column="明细_不含税金额" property="amount"/>
            <result column="明细_税额" property="taxAmount"/>
            <result column="明细_价税合计" property="totalAmount"/>
            <result column="购买方名称" property="buyerName"/>
            <result column="购买方统一社会信用代码" property="buyerCreditCode"/>
            <result column="销售方名称" property="sellerName"/>
            <result column="销售方统一社会信用代码" property="sellerCreditCode"/>
            <result column="明细_备注" property="remark"/>
        </collection>
    </resultMap>

    <!-- 分页查询结果映射 -->
    <resultMap id="InvoiceNoticePageResultMap" type="com.erp.controller.finance.dto.InvoiceNoticePageResponse">
        <id column="开票通知单编号" property="noticeId"/>
        <result column="开票通知单号" property="noticeNo"/>
        <result column="合同编号" property="contractId"/>
        <result column="合同号" property="contractNo"/>
        <result column="合同名称" property="contractName"/>
        <result column="客户编码" property="customerId"/>
        <result column="客户名称" property="customerName"/>
        <result column="结算单编号" property="mainSettlementId"/>
        <result column="主结算单编码" property="mainSettlementCode"/>
        <result column="已绑定结算摘要" property="boundSettlementSummary"/>
        <result column="开票类型" property="invoiceType"/>
        <result column="备注" property="remark"/>
        <result column="状态" property="status"/>
        <result column="申请人编码" property="applicantId"/>
        <result column="申请人姓名" property="applicantName"/>
        <result column="审批人编码" property="approverId"/>
        <result column="审批人姓名" property="approverName"/>
        <result column="审批意见" property="approvalOpinion"/>
        <result column="办理人编码" property="handlerId"/>
        <result column="办理人姓名" property="handlerName"/>
        <result column="已开票张数" property="invoiceCount"/>
        <result column="已开票价税合计" property="totalAmount"/>
        <result column="开票完成时间" property="issuedAt"/>
        <result column="创建时间" property="createTime"/>
        <result column="创建人姓名" property="creatorName"/>
        <result column="创建人编码" property="createUserId"/>
        <result column="创建人编码" property="creatorId"/>
        <result column="更新时间" property="updateTime"/>
        <result column="更新人编码" property="updateUserId"/>
        <result column="version" property="version"/>
    </resultMap>

    <!-- 分页查询开票通知单列表（支持关联查询结算单信息） -->
    <select id="selectPageWithSettlement" resultMap="InvoiceNoticePageResultMap">
        SELECT
            in_notice.开票通知单编号,
            in_notice.开票通知单号,
            in_notice.合同编号,
            in_notice.合同号,
            in_notice.合同名称,
            in_notice.客户编码,
            in_notice.客户名称,
            in_notice.结算单编号,
            s.结算单单号 AS 主结算单编码,
            in_notice.已绑定结算摘要,
            in_notice.开票类型,
            in_notice.备注,
            in_notice.状态,
            in_notice.申请人编码,
            in_notice.申请人姓名,
            in_notice.审批人编码,
            in_notice.审批人姓名,
            in_notice.审批意见,
            in_notice.办理人编码,
            in_notice.办理人姓名,
            in_notice.已开票张数,
            in_notice.已开票价税合计,
            in_notice.开票完成时间,
            in_notice.创建时间,
            ce.员工姓名 AS 创建人姓名,
            in_notice.创建人编码,
            in_notice.更新时间,
            in_notice.更新人编码,
            in_notice.version
        FROM INVOICE_NOTICE in_notice
        LEFT JOIN SETTLEMENT s ON in_notice.结算单编号 = s.结算单编号
        LEFT JOIN EMPLOYEE ce ON in_notice.创建人编码 = ce.员工编码
        <where>
            <if test="creatorFilter != null">
                AND in_notice.创建人编码 = #{creatorFilter}
            </if>
            <if test="request.noticeNo != null and request.noticeNo.trim() != ''">
                AND in_notice.开票通知单号 LIKE CONCAT('%', #{request.noticeNo}, '%')
            </if>
            <if test="request.contractNo != null and request.contractNo.trim() != ''">
                AND in_notice.合同号 LIKE CONCAT('%', #{request.contractNo}, '%')
            </if>
            <if test="request.contractName != null and request.contractName.trim() != ''">
                AND in_notice.合同名称 LIKE CONCAT('%', #{request.contractName}, '%')
            </if>
            <if test="request.customerName != null and request.customerName.trim() != ''">
                AND in_notice.客户名称 LIKE CONCAT('%', #{request.customerName}, '%')
            </if>
            <if test="request.mainSettlementNo != null and request.mainSettlementNo.trim() != ''">
                AND s.结算单单号 LIKE CONCAT('%', #{request.mainSettlementNo}, '%')
            </if>
            <if test="request.invoiceType != null and request.invoiceType.trim() != ''">
                AND in_notice.开票类型 = #{request.invoiceType}
            </if>
            <if test="request.status != null and request.status.trim() != ''">
                AND in_notice.状态 = #{request.status}
            </if>
            <if test="request.applicantId != null">
                AND in_notice.申请人编码 = #{request.applicantId}
            </if>
            <if test="request.applicantName != null and request.applicantName.trim() != ''">
                AND in_notice.申请人姓名 LIKE CONCAT('%', #{request.applicantName}, '%')
            </if>
            <if test="request.handlerId != null">
                AND in_notice.办理人编码 = #{request.handlerId}
            </if>
            <if test="request.startTime != null">
                AND in_notice.创建时间 >= #{request.startTime}
            </if>
            <if test="request.endTime != null">
                AND in_notice.创建时间 &lt;= #{request.endTime}
            </if>
            <if test="request.issuedAtStart != null">
                AND in_notice.开票完成时间 >= #{request.issuedAtStart}
            </if>
            <if test="request.issuedAtEnd != null">
                AND in_notice.开票完成时间 &lt;= #{request.issuedAtEnd}
            </if>
        </where>
        <choose>
            <when test="request.sortField != null and request.sortField != '' and request.sortOrder != null and request.sortOrder != ''">
                <trim prefix="ORDER BY" suffixOverrides=",">
                    <trim suffixOverrides=",">
                        <choose>
                            <when test="request.sortField == 'noticeId'">in_notice.开票通知单编号 ${request.sortOrder}</when>
                            <when test="request.sortField == 'noticeNo'">in_notice.开票通知单号 ${request.sortOrder}</when>
                            <when test="request.sortField == 'contractNo'">in_notice.合同号 ${request.sortOrder}</when>
                            <when test="request.sortField == 'contractName'">in_notice.合同名称 ${request.sortOrder}</when>
                            <when test="request.sortField == 'customerName'">in_notice.客户名称 ${request.sortOrder}</when>
                            <when test="request.sortField == 'status'">in_notice.状态 ${request.sortOrder}</when>
                            <when test="request.sortField == 'mainSettlementNo'">s.结算单单号 ${request.sortOrder}</when>
                            <when test="request.sortField == 'invoiceType'">in_notice.开票类型 ${request.sortOrder}</when>
                            <when test="request.sortField == 'applicantName'">in_notice.申请人姓名 ${request.sortOrder}</when>
                            <when test="request.sortField == 'approverName'">in_notice.审批人姓名 ${request.sortOrder}</when>
                            <when test="request.sortField == 'handlerName'">in_notice.办理人姓名 ${request.sortOrder}</when>
                            <when test="request.sortField == 'createdAt' or request.sortField == 'createTime'">in_notice.创建时间 ${request.sortOrder}</when>
                            <when test="request.sortField == 'issuedAt'">in_notice.开票完成时间 ${request.sortOrder}</when>
                            <when test="request.sortField == 'invoiceCount'">in_notice.已开票张数 ${request.sortOrder}</when>
                            <when test="request.sortField == 'totalAmount'">in_notice.已开票价税合计 ${request.sortOrder}</when>
                            <otherwise>in_notice.创建时间 DESC</otherwise>
                        </choose>
                    </trim>
                </trim>
            </when>
            <otherwise>
                ORDER BY in_notice.创建时间 DESC
            </otherwise>
        </choose>
    </select>

    <!-- 查询开票通知单详情（包含关联的发票列表和客户信息） -->
    <select id="selectDetailWithInvoices" resultMap="InvoiceNoticeDetailResultMap">
        SELECT
            in_notice.开票通知单编号,
            in_notice.开票通知单号,
            in_notice.合同编号,
            in_notice.合同号,
            in_notice.合同名称,
            in_notice.客户编码,
            in_notice.客户名称,
            in_notice.结算单编号,
            s.结算单单号 AS settlementCode,
            s.结算类型 AS settlementType,
            s.结算周期起 AS settlementPeriodStart,
            s.结算周期止 AS settlementPeriodEnd,
            s.结算金额 AS settlementAmount,
            s.已收金额 AS receivedAmount,
            s.状态 AS settlementStatus,
            s.创建时间 AS settlementCreateTime,
            e.员工姓名 AS settlementCreatorName,
            in_notice.已绑定结算摘要,
            in_notice.开票类型,
            in_notice.备注,
            in_notice.状态,
            in_notice.申请人编码,
            in_notice.申请人姓名,
            in_notice.审批人编码,
            in_notice.审批人姓名,
            in_notice.审批意见,
            in_notice.办理人编码,
            in_notice.办理人姓名,
            in_notice.已开票张数,
            in_notice.已开票价税合计,
            in_notice.开票完成时间,
            in_notice.创建时间,
            in_notice.创建人编码,
            in_notice.更新时间,
            in_notice.更新人编码,
            in_notice.version,
            FALSE AS locked,
            NULL AS lockReason,
            c.企业名称,
            c.统一社会信用代码,
            c.地址,
            c.电话,
            c.法定代表人,
            c.联系人,
            c.联系电话,
            ini.明细编号,
            ini.开票通知单编号 AS 明细_开票通知单编号,
            ini.发票编号,
            ini.发票号码,
            ini.发票代码,
            ini.开票日期,
            ini.发票类型,
            ini.发票形式,
            ini.不含税金额 AS 明细_不含税金额,
            ini.税额 AS 明细_税额,
            ini.价税合计 AS 明细_价税合计,
            ini.购买方名称,
            ini.购买方统一社会信用代码,
            ini.销售方名称,
            ini.销售方统一社会信用代码,
            ini.备注 AS 明细_备注
        FROM INVOICE_NOTICE in_notice
        LEFT JOIN CONTRACT contract ON in_notice.合同编号 = contract.合同编号
        LEFT JOIN CUSTOMER c ON contract.客户编码 = c.客户编码
        LEFT JOIN SETTLEMENT s ON in_notice.结算单编号 = s.结算单编号
        LEFT JOIN EMPLOYEE e ON s.制单人编码 = e.员工编码
        LEFT JOIN INVOICE_NOTICE_INVOICE ini ON in_notice.开票通知单编号 = ini.开票通知单编号
        WHERE in_notice.开票通知单编号 = #{noticeId}
        ORDER BY COALESCE(ini.明细编号, 0) ASC
    </select>

</mapper>

